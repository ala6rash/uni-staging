@using Uni_Connect.Models
@{
    ViewData["Title"] = "Admin Command Center — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var facultyStats = ViewBag.FacultyStats as IEnumerable<dynamic>;
    var recentUsers = ViewBag.RecentUsers as List<User>;
    var recentReports = ViewBag.RecentReports as List<Report>;
    int maxFacultyCount = facultyStats?.Any() == true ? facultyStats.Max(f => (int)f.Count) : 1;
}

<div style="max-width: 1200px; margin: 0 auto;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px;">
        <div>
            <h1 style="font-size: 32px; font-weight: 900; color: var(--text); margin-bottom: 4px;">Admin Command Center</h1>
            <p style="color: var(--text-2); font-size: 15px;">Real-time platform overview and system moderation.</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <a asp-action="ManageUsers" class="btn btn-ghost" style="display:inline-flex; align-items:center; gap:8px;"><i data-lucide="users"></i> Manage Users</a>
            <a asp-action="ManageReports" class="btn btn-rose" style="display:inline-flex; align-items:center; gap:8px;"><i data-lucide="flag"></i> Reports Feed</a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px;">
        <div class="card" style="padding: 24px; border: 1.5px solid var(--border); position: relative; overflow: hidden;">
            <div style="font-size: 13px; font-weight: 700; color: var(--text-2); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px;">Total Students</div>
            <div style="font-size: 32px; font-weight: 900; color: var(--indigo);">@ViewBag.UserCount</div>
            <i data-lucide="users" style="position: absolute; right: -10px; bottom: -10px; width: 80px; height: 80px; opacity: 0.05; color: var(--indigo);"></i>
        </div>
        <div class="card" style="padding: 24px; border: 1.5px solid var(--border); position: relative; overflow: hidden;">
            <div style="font-size: 13px; font-weight: 700; color: var(--text-2); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px;">Active Questions</div>
            <div style="font-size: 32px; font-weight: 900; color: var(--violet);">@ViewBag.PostCount</div>
            <i data-lucide="help-circle" style="position: absolute; right: -10px; bottom: -10px; width: 80px; height: 80px; opacity: 0.05; color: var(--violet);"></i>
        </div>
        <div class="card" style="padding: 24px; border: 1.5px solid var(--border); position: relative; overflow: hidden;">
            <div style="font-size: 13px; font-weight: 700; color: var(--text-2); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px;">Total Solutions</div>
            <div style="font-size: 32px; font-weight: 900; color: var(--emerald);">@ViewBag.AnswerCount</div>
            <i data-lucide="check-circle-2" style="position: absolute; right: -10px; bottom: -10px; width: 80px; height: 80px; opacity: 0.05; color: var(--emerald);"></i>
        </div>
        <div class="card" style="padding: 24px; border: 1.5px solid var(--border); position: relative; overflow: hidden; background: var(--rose-light);">
            <div style="font-size: 13px; font-weight: 700; color: var(--rose); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px;">Pending Reports</div>
            <div style="font-size: 32px; font-weight: 900; color: var(--rose);">@ViewBag.ReportCount</div>
            <i data-lucide="alert-circle" style="position: absolute; right: -10px; bottom: -10px; width: 80px; height: 80px; opacity: 0.1; color: var(--rose);"></i>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 32px;">
        <!-- Left Column: Chart & Recent Reports -->
        <div>
            <!-- Faculty Distribution Chart -->
            <div class="card" style="margin-bottom: 32px; padding: 24px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                    <h3 style="font-size: 18px; font-weight: 800;"><i data-lucide="bar-chart-3" style="vertical-align: middle; margin-right: 8px; color: var(--indigo);"></i> Faculty Participation</h3>
                </div>
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    @if (facultyStats != null)
                    {
                        foreach (var stat in facultyStats)
                        {
                            var pct = (int)stat.Count * 100 / maxFacultyCount;
                            <div>
                                <div style="display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 6px;">
                                    <span style="font-weight: 700;">@stat.Faculty</span>
                                    <span style="color: var(--text-2);">@stat.Count students</span>
                                </div>
                                <div style="height: 10px; background: var(--bg); border-radius: 99px; overflow: hidden;">
                                    <div style="width: @pct%; height: 100%; background: linear-gradient(90deg, var(--indigo), var(--violet)); border-radius: 99px;"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Recent Reports -->
            <div class="card" style="padding: 24px;">
                <h3 style="font-size: 18px; font-weight: 800; margin-bottom: 20px;"><i data-lucide="flag" style="vertical-align: middle; margin-right: 8px; color: var(--rose);"></i> Recent Reports</h3>
                @if (recentReports != null && recentReports.Any())
                {
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        @foreach (var report in recentReports)
                        {
                            <div style="display: flex; align-items: center; gap: 16px; padding: 12px; background: var(--bg); border-radius: 12px; border: 1px solid var(--border);">
                                <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--rose-light); color: var(--rose); display: flex; align-items: center; justify-content: center;">
                                    <i data-lucide="alert-triangle" style="width: 20px; height: 20px;"></i>
                                </div>
                                <div style="flex: 1;">
                                    <div style="font-size: 14px; font-weight: 700;">@report.Reason</div>
                                    <div style="font-size: 12px; color: var(--text-2);">Reported by @(report.Reporter?.Name ?? "User") · @report.CreatedAt.ToString("MMM dd")</div>
                                </div>
                                <a asp-action="ManageReports" class="btn btn-ghost btn-sm">Resolve</a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="text-align: center; padding: 40px; color: var(--text-2);">
                        <i data-lucide="check-circle" style="width: 40px; height: 40px; margin-bottom: 12px; opacity: 0.3;"></i>
                        <p>No active reports. Everything looks clean!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Right Column: Recent Users -->
        <div>
            <div class="card" style="padding: 24px; position: sticky; top: calc(var(--navbar-h) + 24px);">
                <h3 style="font-size: 18px; font-weight: 800; margin-bottom: 20px;"><i data-lucide="user-round-plus" style="vertical-align: middle; margin-right: 8px; color: var(--emerald);"></i> Newest Students</h3>
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    @if (recentUsers != null)
                    {
                        foreach (var user in recentUsers)
                        {
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <div class="av av-sm">
                                    <img src="https://ui-avatars.com/api/?name=@user.Name&background=3D52A0&color=fff&size=40" alt="User" />
                                </div>
                                <div style="flex: 1;">
                                    <div style="font-size: 14px; font-weight: 700;">@user.Name</div>
                                    <div style="font-size: 11px; color: var(--text-2);">@user.Faculty · @user.CreatedAt.ToString("MMM dd")</div>
                                </div>
                                <div style="font-size: 12px; font-weight: 800; color: var(--amber);">@user.Points pts</div>
                            </div>
                        }
                    }
                </div>
                <hr style="margin: 20px 0; border: none; border-top: 1px solid var(--border);" />
                <a asp-action="ManageUsers" class="btn btn-primary btn-full" style="text-align: center;">View All Students</a>
            </div>
        </div>
    </div>
</div>
