@using System.Security.Claims
@{
    ViewData["Title"] = "Private Sessions";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var userName = User.FindFirst(ClaimTypes.Name)?.Value;
}

<main class="main">
    <div style="margin-bottom: 32px;">
        <h1 style="font-size: 28px; font-weight: 800; margin-bottom: 4px;">Private Sessions</h1>
        <p style="font-size: 14px; color: var(--text-2);">One-on-one help · 100% voluntary</p>
    </div>

    <!-- Incoming request banner -->
    <div id="new-request-banner" style="display:none; background: var(--indigo-light); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
        <span style="font-size: 24px;">🎉</span>
        <div style="flex: 1;">
            <div style="font-weight: 700;">Session request sent!</div>
            <div style="font-size: 13px; color: var(--text-2);">You will be notified when they respond.</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="this.parentElement.style.display='none'">✕</button>
    </div>

    <div class="tabs">
        <div class="tab active" onclick="showTab('tab-active',this)">Active Sessions</div>
        <div class="tab" onclick="showTab('tab-requests',this)">
            Incoming Requests <span class="nav-badge" style="background: var(--indigo); color: #fff; padding: 2px 6px; border-radius: 6px; font-size: 11px; margin-left: 6px;">2</span>
        </div>
        <div class="tab" onclick="showTab('tab-history',this)">History</div>
    </div>

    <div data-tabs-container>
        <div id="tab-active" data-tab>
            <div class="chat-wrap" style="display: grid; grid-template-columns: 280px 1fr; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); height: 600px; overflow: hidden;">
                <div class="chat-sidebar-panel" style="border-right: 1px solid var(--border); display: flex; flex-direction: column;">
                    <div class="chat-panel-header" style="padding: 16px; font-weight: 700; border-bottom: 1px solid var(--border);">💬 Active (2)</div>
                    <div class="chat-list" style="flex: 1; overflow-y: auto; padding: 12px;">
                        <div class="chat-item active" style="display: flex; gap: 12px; padding: 12px; border-radius: var(--radius); background: var(--indigo-light); cursor: pointer; margin-bottom: 8px;">
                            <div class="av av-sm"><img src="https://ui-avatars.com/api/?name=Rania&background=3D52A0&color=fff" alt="Rania" /></div>
                            <div style="flex: 1; min-width: 0;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-weight: 700; font-size: 13px;">Rania K.</span>
                                    <span style="font-size: 11px; color: var(--text-2);">2m</span>
                                </div>
                                <div style="font-size: 12px; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Sure! Let me explain the LL case...</div>
                            </div>
                        </div>
                        <!-- More items... -->
                    </div>
                </div>
                
                <div class="chat-main" style="display: flex; flex-direction: column;">
                    <div class="chat-topbar" style="padding: 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px;">
                        <div class="av av-sm"><img src="https://ui-avatars.com/api/?name=Rania&background=3D52A0&color=fff" alt="Rania" /></div>
                        <div style="flex: 1;">
                            <div style="font-weight: 700; font-size: 14px;">Rania K. <span style="font-size: 11px; color: var(--indigo); border: 1px solid var(--indigo); border-radius: 4px; padding: 1px 4px; margin-left: 6px;">✓ Verified Tutor</span></div>
                            <div style="font-size: 11px; color: var(--text-2);">● Online now</div>
                        </div>
                    </div>
                    <div class="chat-messages" style="flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 16px; background: #fbfbfc;">
                        <!-- Messages go here -->
                    </div>
                    <div class="chat-input-bar" style="padding: 16px; border-top: 1px solid var(--border); display: flex; gap: 12px;">
                        <input type="text" onkeydown="if(event.key==='Enter')sendMsg()" placeholder="Type your message..." class="form-input" style="flex: 1;" />
                        <button class="btn btn-primary" onclick="sendMsg()">Send <i data-lucide="send" style="width:14px; height:14px; margin-left:4px;"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-requests" data-tab class="hidden">
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <!-- Request Card -->
                <div class="card" style="display: flex; gap: 16px; align-items: flex-start;">
                    <div class="av av-lg"><img src="https://ui-avatars.com/api/?name=Lina&background=3D52A0&color=fff" alt="Lina" /></div>
                    <div style="flex: 1;">
                        <div style="margin-bottom: 4px;">
                            <span style="font-weight: 700;">Lina H.</span>
                            <span class="chip chip-violet" style="margin-left: 8px;">Engineering · Year 2</span>
                        </div>
                        <p style="font-size: 14px; color: var(--text-2); line-height: 1.6;">
                            Requesting help with <strong>MATH201 — Eigenvalues</strong>. I need to understand the process before my exam tomorrow.
                        </p>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <button class="btn btn-primary btn-sm" onclick="showToast('✅ Session accepted!')">Accept</button>
                        <button class="btn btn-ghost btn-sm" style="color: var(--text-2);">Decline</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-history" data-tab class="hidden">
             <!-- History Items -->
        </div>
    </div>
</main>

<!-- SignalR & Chat Logic -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    const me = {
        id: "@(userId)",
        name: "@(userName)"
    };
    const ROOM_ID = String("@(userId)"); 
    
    let myConnectionId = null;
    let connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();
    
    connection.start()
        .then(() => {
            myConnectionId = connection.connectionId;
            return connection.invoke("JoinRoom", ROOM_ID);
        })
        .catch(err => console.error("SignalR Connection error:", err));
    
    connection.on("ReceiveMessage", (connectionId, senderId, message, time) => {
        const side = connectionId === myConnectionId ? "me" : "them";
        appendMessage(side, message, time);
    });
    
    function sendMsg() {
        const inp = document.querySelector('.chat-input-bar input');
        const message = inp.value.trim();
        if (!message) return;
        
        connection.invoke("SendMessage", ROOM_ID, message)
            .catch(err => console.error(err.toString()));
        
        inp.value = "";
    }
    
    function appendMessage(side, content, time) {
        const msgs = document.querySelector('.chat-messages');
        const wrapper = document.createElement('div');
        
        if (side === "me") {
            wrapper.style.cssText = "align-self: flex-end; max-width: 80%;";
            wrapper.innerHTML = `
                <div style="background: var(--indigo); color: #fff; padding: 12px 16px; border-radius: 12px 12px 0 12px; font-size: 14px;">${escapeHtml(content)}</div>
                <div style="font-size: 11px; color: var(--text-2); margin-top: 4px; text-align: right;">${time}</div>
            `;
        } else {
            wrapper.style.cssText = "align-self: flex-start; max-width: 80%;";
            wrapper.innerHTML = `
                <div style="background: #fff; border: 1px solid var(--border); padding: 12px 16px; border-radius: 12px 12px 12px 0; font-size: 14px;">${escapeHtml(content)}</div>
                <div style="font-size: 11px; color: var(--text-2); margin-top: 4px;">${time}</div>
            `;
        }
        
        msgs.appendChild(wrapper);
        msgs.scrollTop = msgs.scrollHeight;
    }

    function escapeHtml(str) {
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
</script>