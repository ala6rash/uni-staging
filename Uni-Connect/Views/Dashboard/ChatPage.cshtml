@using System.Security.Claims
@{
    ViewData["Title"] = "Private Session — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var currentUserId = ViewBag.CurrentUserId as int? ?? 0;
    var session = ViewBag.Session as Uni_Connect.Models.PrivateSession;
    var otherUser = ViewBag.OtherUser as Uni_Connect.Models.User;
    var sessionId = session?.PrivateSessionID ?? 0;
    var sidebarSessions = ViewBag.SidebarSessions as List<Uni_Connect.Models.PrivateSession> ?? new List<Uni_Connect.Models.PrivateSession>();
}

<style>
    .chat-layout {
        display: flex;
        gap: 16px;
        max-width: 1100px;
        margin: 0 auto;
        height: calc(100vh - 120px);
    }
    /* Sidebar */
    .chat-sidebar {
        width: 260px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        background: white;
        border: 1.5px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }
    .chat-sidebar-header {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        font-weight: 800;
        font-size: 13px;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .chat-sidebar-list { flex: 1; overflow-y: auto; }
    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        text-decoration: none;
        color: inherit;
        border-bottom: 1px solid #F1F5F9;
        transition: background .15s;
    }
    .sidebar-item:hover { background: #F8FAFF; }
    .sidebar-item.active-session { background: #EEF2FF; border-left: 3px solid #3D52A0; }
    .sidebar-name { font-weight: 700; font-size: 13px; color: var(--text); }
    .sidebar-last-msg { font-size: 11px; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px; }
    /* Main chat */
    .chat-shell {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        min-width: 0;
    }
    .chat-topbar {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 14px;
        background: #fff;
        flex-shrink: 0;
    }
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        background: #f8f9fc;
    }
    .msg-me { align-self: flex-end; max-width: 72%; }
    .msg-them { align-self: flex-start; max-width: 72%; }
    .msg-bubble-me {
        background: var(--indigo);
        color: #fff;
        padding: 11px 16px;
        border-radius: 16px 16px 4px 16px;
        font-size: 14px;
        line-height: 1.55;
        word-break: break-word;
    }
    .msg-bubble-them {
        background: #fff;
        border: 1.5px solid #E2E8F0;
        color: var(--text);
        padding: 11px 16px;
        border-radius: 16px 16px 16px 4px;
        font-size: 14px;
        line-height: 1.55;
        word-break: break-word;
    }
    .msg-time { font-size: 11px; color: var(--text-2); margin-top: 4px; text-align: right; }
    .msg-time.them { text-align: left; }
    .chat-input-bar {
        padding: 14px 16px;
        border-top: 1px solid var(--border);
        display: flex;
        gap: 10px;
        background: #fff;
        flex-shrink: 0;
    }
    @@media (max-width: 700px) {
        .chat-sidebar { display: none; }
    }
</style>

<!-- Back link -->
<div style="max-width:1100px; margin: 0 auto 12px; padding: 0 4px;">
    <a asp-action="Sessions" asp-controller="Dashboard" style="font-size:13px; color:var(--indigo); font-weight:700; text-decoration:none; display:inline-flex; align-items:center; gap:6px;">
        <i data-lucide="arrow-left" style="width:15px; height:15px;"></i> Back to Sessions
    </a>
</div>

<div class="chat-layout">

    <!-- ── Sidebar: other active sessions ── -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <i data-lucide="message-square" style="width:15px; height:15px; color:#3D52A0;"></i>
            Active Sessions
        </div>
        <div class="chat-sidebar-list">
            <!-- Current session highlighted -->
            <a href="@Url.Action("ChatPage", "Dashboard", new { id = sessionId })" class="sidebar-item active-session">
                <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(otherUser?.Name ?? "User"))&background=3D52A0&color=fff&size=36"
                     alt="" style="width:36px; height:36px; border-radius:50%; flex-shrink:0;" />
                <div style="min-width:0;">
                    <div class="sidebar-name">@(otherUser?.Name ?? "Unknown")</div>
                    <div class="sidebar-last-msg">
                        @{var lastHere = session?.Messages?.OrderByDescending(m => m.SentAt).FirstOrDefault();}
                        @(lastHere?.MessageText ?? "No messages yet")
                    </div>
                </div>
            </a>
            @foreach (var s in sidebarSessions)
            {
                var sOther = s.StudentID == currentUserId ? s.Helper : s.Student;
                var sLast = s.Messages?.OrderByDescending(m => m.SentAt).FirstOrDefault();
                <a href="@Url.Action("ChatPage", "Dashboard", new { id = s.PrivateSessionID })" class="sidebar-item">
                    <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(sOther?.Name ?? "User"))&background=7091E6&color=fff&size=36"
                         alt="" style="width:36px; height:36px; border-radius:50%; flex-shrink:0;" />
                    <div style="min-width:0;">
                        <div class="sidebar-name">@(sOther?.Name ?? "Unknown")</div>
                        <div class="sidebar-last-msg">@(sLast?.MessageText ?? "No messages yet")</div>
                    </div>
                </a>
            }
            @if (!sidebarSessions.Any())
            {
                <div style="padding:20px 14px; font-size:12px; color:var(--text-2); text-align:center;">No other active sessions</div>
            }
        </div>
        <div style="padding:12px 14px; border-top:1px solid var(--border); font-size:11px; color:var(--text-2); display:flex; align-items:center; gap:5px;">
            <i data-lucide="clock" style="width:12px; height:12px;"></i> Sessions auto-close after 24h
        </div>
    </div>

    <!-- ── Main chat ── -->
    <div class="chat-shell">
        <!-- Top bar -->
        <div class="chat-topbar">
            <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(otherUser?.Name ?? "User"))&background=3D52A0&color=fff&size=44"
                 alt="@(otherUser?.Name ?? "User")" style="width:44px; height:44px; border-radius:50%; flex-shrink:0;" />
            <div style="flex:1;">
                <div style="font-weight:800; font-size:15px; color:var(--text);">@(otherUser?.Name ?? "Unknown")</div>
                <div style="font-size:12px; color:var(--text-2);">@(otherUser?.Faculty ?? "")</div>
            </div>
            <span style="font-size:12px; color:#64748B; background:#F1F5F9; padding:4px 12px; border-radius:99px; font-weight:600;">
                Session #@sessionId
            </span>
        </div>

        <!-- Messages -->
        <div class="chat-messages" id="chat-messages">
            @if (session?.Messages != null && session.Messages.Any())
            {
                foreach (var msg in session.Messages)
                {
                    var isMine = msg.SenderID == currentUserId;
                    <div class="@(isMine ? "msg-me" : "msg-them")">
                        <div class="@(isMine ? "msg-bubble-me" : "msg-bubble-them")">@msg.MessageText</div>
                        <div class="msg-time @(isMine ? "" : "them")">@msg.SentAt.ToString("HH:mm")</div>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center; color:var(--text-2); font-size:14px; margin-top:60px;" data-empty>
                    <div style="font-size:36px; margin-bottom:12px;">💬</div>
                    <div style="font-weight:700; margin-bottom:4px;">No messages yet</div>
                    <div style="font-size:13px;">Say hello to get the conversation started!</div>
                </div>
            }
        </div>

        <!-- Input bar -->
        <div class="chat-input-bar">
            <input type="text" id="msg-input" class="form-input" style="flex:1;"
                   placeholder="Type a message..." maxlength="1000"
                   onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); sendMsg(); }" />
            <button class="btn btn-primary" onclick="sendMsg()" style="flex-shrink:0;">
                <i data-lucide="send" style="width:16px; height:16px;"></i>
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    const ROOM_ID = "@sessionId";
    const MY_ID = @currentUserId;

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    connection.start()
        .then(() => connection.invoke("JoinRoom", ROOM_ID))
        .catch(err => console.error("SignalR error:", err));

    connection.on("ReceiveMessage", (connectionId, senderId, message, time) => {
        const isMine = parseInt(senderId) === MY_ID;
        appendMessage(isMine, message, time);
    });

    function sendMsg() {
        const inp = document.getElementById('msg-input');
        const message = inp.value.trim();
        if (!message) return;
        connection.invoke("SendMessage", ROOM_ID, message).catch(err => console.error(err));
        inp.value = "";
    }

    function appendMessage(isMine, content, time) {
        const msgs = document.getElementById('chat-messages');
        const empty = msgs.querySelector('[data-empty]');
        if (empty) empty.remove();
        const wrapper = document.createElement('div');
        wrapper.className = isMine ? 'msg-me' : 'msg-them';
        wrapper.innerHTML = `
            <div class="${isMine ? 'msg-bubble-me' : 'msg-bubble-them'}">${escapeHtml(content)}</div>
            <div class="msg-time${isMine ? '' : ' them'}">${time}</div>
        `;
        msgs.appendChild(wrapper);
        msgs.scrollTop = msgs.scrollHeight;
    }

    function escapeHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    document.addEventListener('DOMContentLoaded', () => {
        const msgs = document.getElementById('chat-messages');
        msgs.scrollTop = msgs.scrollHeight;
    });
</script>
}
