@model Uni_Connect.ViewModels.CreatePostViewModel
@{
    ViewData["Title"] = "Ask a Question — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- CreatePost Wizard View -->
<div class="post-wizard-main">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a asp-action="Dashboard" asp-controller="Dashboard"><i data-lucide="home"></i> Home</a>
        <span class="breadcrumb-sep">›</span>
        <span>Ask a Question</span>
    </div>

    <!-- Page header (hidden on success step) -->
    <div class="page-header" id="page-header">
        <h1 class="page-title"><i data-lucide="pencil-line"></i> Ask a Question</h1>
        <p class="page-subtitle">
            Posting costs <strong class="cost-deducted">−10 pts</strong>.
            A great answer earns you <strong class="cost-earned">+5 to +15 pts</strong> back!
        </p>
    </div>

    <!-- Wizard progress bar -->
    <div class="wizard-wrap" id="wizard-bar">
        <div class="wizard-steps">
            <div class="wz-step active" id="ws1">
                <div class="wz-num">1</div>
                <span class="wz-label">Search First</span>
            </div>
            <div class="wz-step" id="ws2">
                <div class="wz-num">2</div>
                <span class="wz-label">Write Question</span>
            </div>
            <div class="wz-step" id="ws3">
                <div class="wz-num">3</div>
                <span class="wz-label">Preview & Post</span>
            </div>
        </div>
        <div class="wizard-progress">
            <div class="wizard-progress-fill" id="wz-progress"></div>
        </div>
    </div>

    <!-- STEP 1 — SEARCH FIRST -->
    <div class="fade-in" id="wz1">
        <div class="card search-card">
            <div class="search-card-header">
                <div class="search-icon-box"><i data-lucide="search"></i></div>
                <div>
                    <div class="search-prompt-title">Check if your question already exists</div>
                    <div class="search-prompt-desc">
                        Search first — you might find an instant answer and save your
                        <strong class="points-highlight">10 pts</strong>.
                        Most questions have already been answered!
                    </div>
                </div>
            </div>
            <div class="search-input-row">
                <input autocomplete="off" class="form-input search-field" id="s1-search"
                       oninput="step1Search(this.value)"
                       placeholder="e.g. AVL tree rotation, trial balance, eigenvalues..." />
                <button type="button" class="btn btn-ghost btn-sm"
                        onclick="step1Search(document.getElementById('s1-search').value)">
                    <i data-lucide="search"></i> Search
                </button>
            </div>
        </div>

        <div class="hidden" id="s1-results">
            <div class="search-results-label">
                <span><i data-lucide="copy"></i> Similar questions found — check these first:</span>
            </div>
            <div id="s1-results-list"></div>
            <div class="search-answer-tip">
                <span class="search-tip-icon"><i data-lucide="lightbulb"></i></span>
                <p class="amber-tip-text">
                    Is your question answered above?
                    <a class="amber-tip-link" href="#">Click to view the full answer</a>
                    and save your 10 pts!
                </p>
            </div>
        </div>

        <div class="hidden search-no-results" id="s1-no-results">
            <span class="search-no-results-icon"><i data-lucide="check-circle"></i></span>
            <p class="search-no-results-text">No similar questions found — yours is unique! Go ahead and post it.</p>
        </div>

        <div class="wizard-step-actions">
            <a href="@Url.Action("Dashboard", "Dashboard")"><button type="button" class="btn btn-ghost">← Cancel</button></a>
            <button type="button" class="btn btn-primary btn-lg" onclick="goToStep2()">
                My question is different → <span class="btn-cost-label">(−10 pts)</span>
            </button>
        </div>
    </div>

    <!-- STEP 2 — WRITE QUESTION -->
    <div class="hidden" id="wz2">
        <form id="create-post-form" method="post" asp-action="CreatePost" asp-controller="Dashboard">
            <div class="card">
                <!-- Title -->
                <div class="form-group">
                    <label class="form-label">Question Title <span class="form-label-req">*</span></label>
                    <input class="form-input" id="s2-title" asp-for="Title" maxlength="150"
                           oninput="updateTitle(); updateCharCount('s2-title', 'tc-title', 10, 150)"
                           placeholder="Start with How, Why, What, When, Where..." />
                    <div class="form-field-footer">
                        <div class="form-hint">Be specific — good: "How does AVL tree LL rotation work?" · bad: "help with AVL"</div>
                        <div class="char-counter char-counter-right" id="tc-title">0/150</div>
                    </div>
                    <div class="form-error" id="err-title">⚠ Please enter a question title (minimum 10 characters)</div>
                </div>

                <!-- Faculty + Course grid -->
                <div class="faculty-course-grid">
                    <div>
                        <label class="form-label">Faculty <span class="form-label-req">*</span></label>
                        <select class="form-input form-select" id="s2-faculty" asp-for="Faculty" onchange="updatePreview()">
                            <option value="">Select your faculty...</option>
                            <option value="IT Faculty">💻 Information Technology</option>
                            <option value="Engineering">⚙️ Engineering &amp; Technology</option>
                            <option value="Business">💼 Business &amp; Finance</option>
                            <option value="Law">⚖️ Faculty of Law</option>
                            <option value="Arts">🎨 Arts &amp; Educational Sciences</option>
                            <option value="Pharmacy">💊 Faculty of Pharmacy</option>
                            <option value="Administrative">📊 Administrative Sciences</option>
                        </select>
                        <div class="form-error" id="err-faculty">⚠ Please select your faculty</div>
                    </div>
                    <div>
                        <label class="form-label">Course Code <span class="form-label-req">*</span></label>
                        <input class="form-input" id="s2-course" asp-for="CourseCode" maxlength="10"
                               oninput="updatePreview()" placeholder="e.g. CS302, MATH201, ACCT101" />
                        <div class="form-hint">The course this question is about</div>
                        <div class="form-error" id="err-course">⚠ Please enter the course code</div>
                    </div>
                </div>

                <!-- Content -->
                <div class="form-group">
                    <label class="form-label">Describe Your Question <span class="form-label-req">*</span></label>
                    <textarea class="form-input form-textarea" id="s2-body" asp-for="Content" maxlength="2000"
                              oninput="updateBody(); updateCharCount('s2-body', 'tc-body', 50, 2000)"
                              placeholder="Explain your question clearly: • What are you trying to understand? • What have you tried? • Where are you stuck?"></textarea>
                    <div class="form-field-footer">
                        <div class="form-hint">Minimum 50 characters — more detail gets faster, better answers</div>
                        <div class="char-counter char-counter-right" id="tc-body">0/2000</div>
                    </div>
                    <div class="form-error" id="err-body">⚠ Please describe your question (minimum 50 characters)</div>
                </div>

                <!-- Tags -->
                <div class="form-group tags-form-group" style="position:relative;">
                    <label class="form-label">
                        Tags <span class="form-label-note">(optional, max 5)</span>
                    </label>
                    <div class="tags-wrap" id="tags-wrap"
                         onclick="document.getElementById('tags-input').focus()">
                        <input class="tags-input" id="tags-input" maxlength="20"
                               onkeydown="handleTagInput(event)"
                               oninput="filterTagSuggestions(this.value)"
                               onblur="setTimeout(()=>hideTagDropdown(),200)"
                               placeholder="Type to search tags..." type="text" autocomplete="off" />
                    </div>
                    <!-- Live tag autocomplete dropdown -->
                    <div id="tag-dropdown" style="display:none; position:absolute; left:0; right:0; background:#fff; border:1.5px solid var(--indigo); border-radius:10px; box-shadow:0 8px 24px rgba(61,82,160,.13); z-index:200; max-height:180px; overflow-y:auto; margin-top:4px;"></div>
                    <div style="margin-top: 10px;">
                        <span style="font-size: 12px; font-weight: 700; color: var(--text-2); margin-right: 8px;">Suggested:</span>
                        <div id="suggested-tags" style="display: inline-flex; gap: 6px; flex-wrap: wrap;">
                            @if (ViewBag.CommonTags != null)
                            {
                                foreach (var tag in ViewBag.CommonTags)
                                {
                                    <span class="chip chip-gray clickable-tag" style="cursor:pointer; font-size:11px;" onclick="addTag('@tag')">+ @tag</span>
                                }
                            }
                        </div>
                    </div>
                    <div class="form-hint">Select from suggestions or type your own. Max 5 tags.</div>
                </div>

                <!-- Image Upload -->
                <div class="form-group" style="margin-top:24px;">
                    <label class="form-label" style="display:flex; justify-content:space-between; align-items:center;">
                        <span>Add an image <span class="form-label-note">(optional)</span></span>
                        <span style="font-size:11px; color:var(--text-3);">Max 5MB • JPG, PNG</span>
                    </label>
                    
                    <div id="image-upload-zone" onclick="document.getElementById('image-input').click()" 
                         style="border:2px dashed var(--border); border-radius:12px; padding:24px; text-align:center; cursor:pointer; background:rgba(248,250,252,0.5); transition:all .2s ease; display:flex; flex-direction:column; align-items:center; gap:8px;">
                        <i data-lucide="image-plus" style="width:32px; height:32px; color:var(--text-3);"></i>
                        <span id="upload-status-text" style="font-size:13px; color:var(--text-2); font-weight:600;">Click to upload a diagram or screenshot</span>
                        <input type="file" id="image-input" name="ImageFile" accept="image/*" style="display:none;" onchange="previewSelectedImage(this)">
                    </div>

                    <div id="image-preview-container" class="hidden" style="margin-top:12px; position:relative; display:inline-block;">
                        <img id="image-preview-img" src="" style="max-width:100%; max-height:200px; border-radius:8px; border:1.5px solid var(--border); box-shadow:var(--shadow-sm);">
                        <button type="button" onclick="removeSelectedImage()" 
                                style="position:absolute; top:-10px; right:-10px; background:var(--rose); color:white; border:none; border-radius:50%; width:24px; height:24px; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:var(--shadow-sm);">
                            <i data-lucide="x" style="width:14px; height:14px;"></i>
                        </button>
                    </div>
                </div>

                <!-- Hidden input for tags to submit with form -->
                <input type="hidden" id="tags-hidden" name="Tags" />
            </div>

            <div class="wizard-step-actions">
                <button type="button" class="btn btn-ghost" onclick="goToStep1()">← Back</button>
                <button type="button" class="btn btn-primary btn-lg" id="btn-preview" onclick="goToStep3()">Preview Question →</button>
            </div>
        </form>
    </div>

    <!-- STEP 3 — PREVIEW & POST -->
    <div class="hidden" id="wz3">
        <div class="posting-cost-banner">
            <span class="posting-cost-icon"><i data-lucide="coins"></i></span>
            <div>
                <div class="posting-cost-title">This will cost 10 points</div>
                <div class="amber-tip-text">
                    Posting a question costs 10 pts. <strong>Best answers earn +15 pts back!</strong>
                </div>
            </div>
        </div>

        <div class="preview-section-label"><i data-lucide="eye"></i> Preview — this is how your question will look:</div>

        <div class="card preview-post-card">
            <div class="preview-post-meta">
                <div class="av av-sm"><img alt="User" id="preview-user-avatar" src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User"))&background=3D52A0&color=fff&size=36" /></div>
                <span class="preview-author-name">@(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value?.Split(' ').First() ?? "You")</span>
                <span class="preview-post-time">· Just now</span>
                <span class="chip chip-indigo preview-faculty-badge" id="prev-faculty-chip"></span>
                <span class="chip chip-gray" id="prev-course-chip"></span>
            </div>
            <div class="preview-post-title" id="prev-title">Your question title will appear here...</div>
            <div class="preview-post-body" id="prev-body">Your question description will appear here...</div>
            
            <div id="prev-image-wrap" class="hidden" style="margin-top:16px;">
                <img id="prev-image-display" src="" style="max-width:100%; border-radius:12px; border:1px solid var(--border);">
            </div>

            <div class="preview-post-tags" id="prev-tags"></div>
            <div class="preview-post-stats">
                <span><i data-lucide="thumbs-up"></i> 0</span>
                <span><i data-lucide="message-square"></i> 0 answers</span>
                <span><i data-lucide="eye"></i> 0 views</span>
                <span class="chip chip-gray preview-status-chip">Open</span>
            </div>
        </div>

        <div class="card checklist-card">
            <div class="checklist-heading"><i data-lucide="check-circle-2"></i> Before you post — quick checklist:</div>
            <div class="checklist-items">
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk1" type="checkbox" />
                    My question title is clear and specific
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk2" type="checkbox" />
                    I described what I already tried and where I'm stuck
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk3" type="checkbox" />
                    The faculty and course code are correct
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk4" type="checkbox" />
                    I searched first and this question doesn't already exist
                </label>
            </div>
        </div>

        <div class="wizard-step-actions">
            <button type="button" class="btn btn-ghost" onclick="goToStep2()">← Edit Question</button>
            <button type="button" class="btn btn-primary btn-lg" id="btn-post" onclick="postQuestion()">
                <i data-lucide="rocket"></i> Post Question <span class="btn-cost-label">(−10 pts)</span>
            </button>
        </div>
    </div>

    <!-- STEP 4 — SUCCESS -->
    <div class="hidden fade-in" id="wz4">
        <div class="card success-card-body">
            <div class="success-icon-circle"><i data-lucide="party-popper" style="width:48px; height:48px;"></i></div>
            <h2 class="success-heading">Question posted!</h2>
            <p class="success-description">Your question is now live. The community will start answering soon.</p>
            <p class="success-points-summary">
                You were charged <strong class="cost-deducted">−10 pts</strong>.
            </p>

            <div class="earn-back-panel">
                <div class="earn-back-heading"><i data-lucide="coins" style="margin-right:8px"></i>How to earn your points back:</div>
                <div class="earn-ways-list">
                    <span><i data-lucide="message-square" style="width:14px; height:14px; margin-right:8px; vertical-align:middle;"></i>Post an answer to any question = <strong>+5 pts</strong></span>
                    <span><i data-lucide="thumbs-up" style="width:14px; height:14px; margin-right:8px; vertical-align:middle;"></i>Every upvote on your answers = <strong>+10 pts</strong></span>
                    <span><i data-lucide="check-circle-2" style="width:14px; height:14px; margin-right:8px; vertical-align:middle;"></i>If your answer is marked Best Answer = <strong>+15 pts</strong></span>
                </div>
            </div>

            <div class="success-action-buttons">
                <a asp-action="Dashboard" asp-controller="Dashboard"><button type="button" class="btn btn-primary btn-lg">Back to Home Feed</button></a>
            </div>
        </div>
    </div>

</div>

<!-- Wizard JavaScript -->
<script>
    // State
    const state = { title: '', faculty: '', course: '', body: '', tags: [] };
    const tags = [];

    // Character counter
    function updateCharCount(inputId, counterId, min, max) {
        const inp = document.getElementById(inputId);
        const cnt = document.getElementById(counterId);
        if (!inp || !cnt) return;
        const len = inp.value.length;
        cnt.textContent = len + '/' + max;
        cnt.className = 'char-counter char-counter-right';
        if (len === 0) return;
        if (len < min) cnt.classList.add('char-err');
        else if (len > max * 0.85) cnt.classList.add('char-warn');
        else cnt.classList.add('char-ok');
    }

    // Wizard progress
    function setProgress(step) {
        const pct = { 1: 16, 2: 50, 3: 83, 4: 100 }[step] || 16;
        const bar = document.getElementById('wz-progress');
        if (bar) bar.style.width = pct + '%';
    }

    // Step switcher
    function switchToStep(n) {
        [1, 2, 3, 4].forEach(i => {
            const el = document.getElementById('wz' + i);
            if (el) el.classList.add('hidden');
        });
        [1, 2, 3].forEach(i => {
            const dot = document.getElementById('ws' + i);
            if (!dot) return;
            dot.classList.remove('active', 'done');
            if (i === n) dot.classList.add('active');
            if (i < n) dot.classList.add('done');
        });
        const target = document.getElementById('wz' + n);
        if (target) {
            target.classList.remove('hidden');
            target.classList.add('fade-in');
        }
        const isSuccess = n === 4;
        const wb = document.getElementById('wizard-bar');
        const ph = document.getElementById('page-header');
        if (wb) wb.style.display = isSuccess ? 'none' : '';
        if (ph) ph.style.display = isSuccess ? 'none' : '';
        setProgress(n);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Step 1: Live search from DB
    let searchDebounce = null;
    function step1Search(q) {
        const resultsPanel = document.getElementById('s1-results');
        const noResults = document.getElementById('s1-no-results');
        const list = document.getElementById('s1-results-list');
        q = q.trim();

        if (q.length < 3) {
            if (resultsPanel) resultsPanel.classList.add('hidden');
            if (noResults) noResults.classList.add('hidden');
            return;
        }

        clearTimeout(searchDebounce);
        searchDebounce = setTimeout(async () => {
            try {
                const resp = await fetch('@Url.Action("SearchPostsApi","Dashboard")?q=' + encodeURIComponent(q));
                if (!resp.ok) return;
                const data = await resp.json();
                const matches = data.results;

                if (matches && matches.length && list) {
                    list.innerHTML = '';
                    matches.forEach(m => {
                        const el = document.createElement('a');
                        el.href = '/Dashboard/SinglePost/' + m.id;
                        el.style.cssText = 'display:block;background:#fff;border:1.5px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:10px;text-decoration:none;cursor:pointer;color:inherit;transition:all .2s';
                        el.onmouseover = () => { el.style.borderColor = 'var(--indigo)'; el.style.boxShadow = '0 4px 16px rgba(61,82,160,.12)'; el.style.transform = 'translateY(-1px)'; };
                        el.onmouseout = () => { el.style.borderColor = 'var(--border)'; el.style.boxShadow = 'none'; el.style.transform = 'none'; };
                        el.innerHTML = `
                            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px">
                                <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:${m.solved ? 'var(--emerald-light)' : '#EEF2FF'};color:${m.solved ? '#065F46' : 'var(--indigo)'}">
                                    ${m.solved ? '✓ Solved' : '● Open'}
                                </span>
                                ${m.course ? `<span style="padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:var(--violet-light);color:#5B21B6">${escapeHtml(m.course)}</span>` : ''}
                                <span style="font-size:11px;color:var(--text-2);margin-left:auto">${m.answers} answers · ${m.votes} votes</span>
                            </div>
                            <div style="font-size:14px;font-weight:700;color:var(--indigo)">${escapeHtml(m.title)}</div>`;
                        list.appendChild(el);
                    });
                    if (resultsPanel) resultsPanel.classList.remove('hidden');
                    if (noResults) noResults.classList.add('hidden');
                } else {
                    if (resultsPanel) resultsPanel.classList.add('hidden');
                    if (noResults) noResults.classList.remove('hidden');
                }
            } catch (err) {
                console.error(err);
            }
        }, 350);
    }

    function goToStep1() { switchToStep(1); }
    function goToStep2() { switchToStep(2); }

    // Step 2: Validation
    function validateStep2() {
        let ok = true;
        const title = document.getElementById('s2-title').value.trim();
        const faculty = document.getElementById('s2-faculty').value;
        const course = document.getElementById('s2-course').value.trim();
        const body = document.getElementById('s2-body').value.trim();

        function check(inputId, errId, value, minLen) {
            const inp = document.getElementById(inputId);
            const err = document.getElementById(errId);
            if (value.length < minLen) {
                if (inp) inp.classList.add('error');
                if (err) err.style.display = 'block';
                ok = false;
            } else {
                if (inp) { inp.classList.remove('error'); inp.classList.add('success'); }
                if (err) err.style.display = 'none';
            }
        }
        check('s2-title', 'err-title', title, 10);
        check('s2-faculty', 'err-faculty', faculty, 1);
        check('s2-course', 'err-course', course, 2);
        check('s2-body', 'err-body', body, 50);
        return ok;
    }

    function goToStep3() {
        if (!validateStep2()) {
            showToast('⚠️ Please fix the errors above', 'warn');
            const err = document.querySelector('.form-input.error');
            if (err) err.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }
        state.title = document.getElementById('s2-title').value.trim();
        state.faculty = document.getElementById('s2-faculty').value;
        state.course = document.getElementById('s2-course').value.trim();
        state.body = document.getElementById('s2-body').value.trim();
        updatePreview();
        switchToStep(3);
    }

    // Preview
    function updateTitle() {
        state.title = document.getElementById('s2-title').value;
        updatePreview();
    }
    function updateBody() {
        state.body = document.getElementById('s2-body').value;
        updatePreview();
    }
    function updatePreview() {
        state.faculty = document.getElementById('s2-faculty').value;
        state.course = document.getElementById('s2-course').value;
        const fChip = document.getElementById('prev-faculty-chip');
        const cChip = document.getElementById('prev-course-chip');
        const prevTitle = document.getElementById('prev-title');
        const prevBody = document.getElementById('prev-body');
        if (fChip) fChip.textContent = state.faculty || 'Faculty';
        if (cChip) cChip.textContent = state.course || 'Course';
        if (prevTitle) prevTitle.textContent = state.title || 'Your question title will appear here...';
        if (prevBody) prevBody.textContent = state.body || 'Your question description will appear here...';
        updateTagPreview();
    }

    // Tags
    function handleTagInput(e) {
        const inp = document.getElementById('tags-input');
        if ((e.key === 'Enter' || e.key === ',') && inp) {
            e.preventDefault();
            addTag(inp.value.replace(',', '').trim());
            inp.value = '';
        }
        if (e.key === 'Backspace' && inp && inp.value === '' && tags.length) {
            removeTag(tags.length - 1);
        }
    }
    function addTag(val) {
        if (!val || tags.length >= 5 || tags.includes(val)) return;
        tags.push(val);
        renderTags();
        updateTagPreview();
        document.getElementById('tags-hidden').value = tags.join(',');
    }
    function removeTag(i) {
        tags.splice(i, 1);
        renderTags();
        updateTagPreview();
        document.getElementById('tags-hidden').value = tags.join(',');
    }
    function renderTags() {
        const wrap = document.getElementById('tags-wrap');
        const inp = document.getElementById('tags-input');
        if (!wrap) return;
        wrap.querySelectorAll('.tag-chip').forEach(t => t.remove());
        tags.forEach((t, i) => {
            const chip = document.createElement('div');
            chip.className = 'tag-chip';
            chip.innerHTML = `${escapeHtml(t)}<button type="button" onclick="removeTag(${i})">×</button>`;
            wrap.insertBefore(chip, inp);
        });
    }
    function updateTagPreview() {
        const container = document.getElementById('prev-tags');
        if (!container) return;
        container.innerHTML = '';
        tags.forEach(t => {
            const chip = document.createElement('span');
            chip.className = 'chip chip-gray';
            chip.style.fontSize = '12px';
            chip.textContent = t;
            container.appendChild(chip);
        });
    }

    // --- Image Handling ---
    function previewSelectedImage(input) {
        const file = input.files[0];
        if (file) {
            if (file.size > 5 * 1024 * 1024) {
                showToast("❌ File is too large (max 5MB)", "error");
                input.value = "";
                return;
            }
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('image-preview-img').src = e.target.result;
                document.getElementById('image-preview-container').classList.remove('hidden');
                document.getElementById('image-upload-zone').classList.add('hidden');
                
                // Also update preview step
                document.getElementById('prev-image-display').src = e.target.result;
                document.getElementById('prev-image-wrap').classList.remove('hidden');
            }
            reader.readAsDataURL(file);
        }
    }

    function removeSelectedImage() {
        document.getElementById('image-input').value = "";
        document.getElementById('image-preview-img').src = "";
        document.getElementById('image-preview-container').classList.add('hidden');
        document.getElementById('image-upload-zone').classList.remove('hidden');
        
        document.getElementById('prev-image-display').src = "";
        document.getElementById('prev-image-wrap').classList.add('hidden');
    }

    // Step 3: Post
    async function postQuestion() {
        const unchecked = ['chk1', 'chk2', 'chk3', 'chk4'].filter(id => !document.getElementById(id).checked);
        if (unchecked.length) {
            showToast('⚠️ Please check all boxes before posting', 'warn');
            return;
        }

        const btn = document.getElementById('btn-post');
        if (btn.disabled) return;

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Posting...';

        try {
            const formData = new FormData();
            
            // Add basic fields
            formData.append("Title", document.getElementById('s2-title').value);
            formData.append("Content", document.getElementById('s2-body').value);
            formData.append("Faculty", document.getElementById('s2-faculty').value);
            formData.append("CourseCode", document.getElementById('s2-course').value);
            formData.append("Tags", document.getElementById('tags-hidden').value);
            
            // Add file
            const imgInput = document.getElementById('image-input');
            if (imgInput.files.length > 0) {
                formData.append("ImageFile", imgInput.files[0]);
            }

            const response = await fetch('@Url.Action("CreatePost","Dashboard")', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: formData
            });

            if (response.status === 401) {
                window.location.href = '@Url.Action("Login_Page", "Login")';
                return;
            }

            const result = await response.json();
            if (result.success) {
                // Update global points if possible (sidebar)
                const sidebarPts = document.querySelector('.pts-badge .pts-num');
                if (sidebarPts && result.pointsBalance !== undefined) {
                    sidebarPts.textContent = result.pointsBalance;
                }
                
                // Show success step
                switchToStep(4);
                
                // Add link to the real post
                const successActions = document.querySelector('.success-action-buttons');
                if (successActions && result.postId) {
                    const viewBtn = document.createElement('a');
                    viewBtn.href = `/Dashboard/SinglePost/${result.postId}`;
                    viewBtn.innerHTML = '<button type="button" class="btn btn-emerald btn-lg" style="margin-bottom:10px; display:inline-flex; align-items:center; gap:8px;"><i data-lucide="eye" style="width:20px; height:20px;"></i> View Your Question</button>';
                    successActions.insertBefore(viewBtn, successActions.firstChild);
                    lucide.createIcons();
                }
            } else {
                showToast('❌ ' + (result.message || 'Error occurred'), 'error');
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="rocket"></i> Post Question <span class="btn-cost-label">(−10 pts)</span>';
                lucide.createIcons();
            }
        } catch (err) {
            console.error(err);
            showToast('❌ Failed to post. Please check your connection.', 'error');
            btn.disabled = false;
            btn.innerHTML = '<i data-lucide="rocket"></i> Post Question <span class="btn-cost-label">(−10 pts)</span>';
            lucide.createIcons();
        }
    }

    // Tag autocomplete dropdown
    const ALL_TAGS = [@if (ViewBag.CommonTags != null) { foreach (var tag in ViewBag.CommonTags) { @("'" + tag + "', ") } }];
    function filterTagSuggestions(val) {
        const dd = document.getElementById('tag-dropdown');
        if (!dd) return;
        val = val.trim().toLowerCase();
        if (!val) { dd.style.display = 'none'; return; }
        const matches = ALL_TAGS.filter(t => t.toLowerCase().includes(val) && !tags.includes(t));
        if (!matches.length) { dd.style.display = 'none'; return; }
        dd.innerHTML = matches.slice(0, 8).map(t =>
            `<div onclick="pickDropdownTag('${escapeHtml(t)}')" style="padding:10px 16px;cursor:pointer;font-size:13px;font-weight:600;transition:background .15s;" onmouseover="this.style.background='var(--indigo-light)'" onmouseout="this.style.background=''">${escapeHtml(t)}</div>`
        ).join('');
        dd.style.display = 'block';
    }
    function pickDropdownTag(t) {
        addTag(t);
        document.getElementById('tags-input').value = '';
        hideTagDropdown();
    }
    function hideTagDropdown() {
        const dd = document.getElementById('tag-dropdown');
        if (dd) dd.style.display = 'none';
    }

    // Toast
    function showToast(msg, type = '') {
        document.querySelector('.toast')?.remove();
        const el = document.createElement('div');
        el.className = 'toast' + (type ? ' toast-' + type : '');
        el.innerHTML = msg;
        document.body.appendChild(el);
        setTimeout(() => {
            el.style.opacity = '0';
            el.style.transition = 'opacity .4s';
            setTimeout(() => el.remove(), 400);
        }, 3500);
    }

    // Utility
    function escapeHtml(str) {
        return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // Init
    document.addEventListener('DOMContentLoaded', () => {
        setProgress(1);
        // Sync preview avatar with nav avatar after stats load
        setTimeout(() => {
            const navAv = document.getElementById('navAvatar');
            const previewAv = document.getElementById('preview-user-avatar');
            if (navAv && previewAv && navAv.src) previewAv.src = navAv.src;
        }, 1200);
    });
</script>
