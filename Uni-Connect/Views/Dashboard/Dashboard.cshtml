@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "Community Dashboard — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <style>
        .dashboard-header { margin-bottom: 32px; }
        .dashboard-title { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
        .dashboard-subtitle { font-size: 14px; color: var(--text-2); }
        
        .tab-container { display: flex; gap: 20px; margin-bottom: 28px; border-bottom: 2px solid var(--border); padding-bottom: 0; }
        .tab-btn {
            padding: 12px 0; background: none; border: none;
            font-size: 14px; font-weight: 600; color: var(--text-2);
            cursor: pointer; border-bottom: 3px solid transparent;
            margin-bottom: -2px; transition: all .2s;
            text-decoration: none;
        }
        .tab-btn:hover { color: var(--indigo); }
        .tab-btn.active { color: var(--indigo); font-weight: 700; border-bottom-color: var(--indigo); }
        
        .questions-list { 
            display: flex; flex-direction: column; gap: 24px; 
            position: relative; padding-bottom: 40px;
        }
        
        .q-card-enhanced {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
            border: 1px solid var(--border);
            border-radius: 16px; padding: 24px;
            cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: block; text-decoration: none;
            color: inherit; position: relative; z-index: 1;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }
        .q-card-enhanced:hover {
            box-shadow: var(--shadow-lg); transform: translateY(-4px) scale(1.01);
            border-color: var(--indigo); background: #fff;
        }
        
        .q-header {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 12px; flex-wrap: wrap;
        }
        
        .q-avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; }
        
        .q-meta {
            display: flex; align-items: center; gap: 8px;
            flex-wrap: wrap; font-size: 12px;
        }
        .q-author { font-weight: 700; color: var(--text); font-size: 13px; }
        .q-date { color: var(--text-2); }
        
        .q-title {
            font-size: 15px; font-weight: 700;
            margin-bottom: 8px; line-height: 1.4;
            color: var(--text);
        }
        
        .q-content {
            font-size: 13px; color: var(--text-2);
            line-height: 1.6; margin-bottom: 12px;
        }
        
        .q-tags {
            display: flex; align-items: center; gap: 8px;
            margin-bottom: 12px; flex-wrap: wrap;
        }
        
        .q-stats {
            display: flex; gap: 16px; font-size: 13px;
            color: var(--text-2);
        }
        
        .empty-state {
            text-align: center; padding: 60px 24px;
            background: var(--surface); border-radius: var(--radius);
        }
        .empty-icon { font-size: 48px; margin-bottom: 16px; }
        .empty-title { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: var(--text); }
        .empty-text { font-size: 14px; color: var(--text-2); margin-bottom: 24px; }
    </style>
}

<div style="max-width: 1000px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="dashboard-header">
        <h1 class="dashboard-title">Welcome back, @(Model.Name.Split(' ').First())! 👋</h1>
        <p class="dashboard-subtitle">See what's happening in your community today</p>
    </div>

    <!-- Tabs (Not implemented yet, placeholder) -->
    <!-- Tabs -->
    <div class="tab-container">
        <a href="@Url.Action("Dashboard", new { filter = "All", search = ViewBag.SearchQuery })" class="tab-btn @(ViewBag.ActiveFilter == "All" ? "active" : "")"><i data-lucide="layers"></i> All Questions</a>
        <a href="@Url.Action("Dashboard", new { filter = "Faculty", search = ViewBag.SearchQuery })" class="tab-btn @(ViewBag.ActiveFilter == "Faculty" ? "active" : "")"><i data-lucide="user-round-plus"></i> My Faculty</a>
        <a href="@Url.Action("Dashboard", new { filter = "Trending", search = ViewBag.SearchQuery })" class="tab-btn @(ViewBag.ActiveFilter == "Trending" ? "active" : "")"><i data-lucide="flame"></i> Trending</a>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
    {
        <div style="margin-bottom: 20px; color: var(--text-2); font-size: 14px; display: flex; align-items: center; gap: 8px;">
            <i data-lucide="search" style="width:16px; height:16px;"></i>
            Showing results for "@ViewBag.SearchQuery" 
            <a href="@Url.Action("Dashboard", new { filter = ViewBag.ActiveFilter })" style="color: var(--rose); margin-left: 8px; text-decoration: none; font-weight: 600;">Clear search</a>
        </div>
    }

    <!-- Main Content Grid -->
    <!-- Faculty Filter Pills -->
    <div style="margin-bottom: 24px; display: flex; gap: 10px; overflow-x: auto; padding: 4px 0; scrollbar-width: none;" class="hide-scrollbar">
        @{
            var currentFaculty = Context.Request.Query["filter"].ToString() == "Faculty" ? Context.Request.Query["faculty"].ToString() : "All";
            var faculties = new[] { "All", "Faculty of Information Technology", "Faculty of Engineering", "Faculty of Business", "Faculty of Law", "Faculty of Pharmacy" };
            foreach(var fac in faculties)
            {
                var isActive = (fac == "All" && currentFaculty == "All") || (fac == currentFaculty);
                <a href="@(fac == "All" ? Url.Action("Dashboard") : Url.Action("Dashboard", new { filter = "Faculty", faculty = fac }))" 
                   class="chip @(isActive ? "chip-indigo" : "chip-white")" 
                   style="white-space: nowrap; padding: 8px 18px; cursor: pointer; text-decoration: none; font-weight: 700; font-size: 13px; transition: all 0.2s; border: 1.5px solid @(isActive ? "var(--indigo)" : "var(--border)");">
                    @fac.Replace("Faculty of ", "")
                </a>
            }
        }
    </div>

    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 32px; align-items: flex-start;">
        <!-- Questions Feed -->
        <div class="questions-list">
            <div class="timeline-line"></div>
        @{
            var posts = ViewBag.Posts as List<Post>;
            if (posts != null && posts.Count > 0)
            {
                foreach (var post in posts)
                {
                    <div class="q-card-enhanced" onclick="window.location.href='@Url.Action("SinglePost", new { id = post.PostID })'">
                        <div class="timeline-dot"></div>
                        <!-- Header with author info -->
                        <div class="q-header">
                               <img src='@(string.IsNullOrEmpty(post.User?.ProfileImageUrl) ? $"https://ui-avatars.com/api/?name={post.User?.Name ?? "User"}&background=3D52A0&color=fff" : post.User.ProfileImageUrl)' 
                                   alt="Avatar" class="q-avatar" />
                            <div>
                                <div class="q-meta">
                                    @{ var authorName = post.User?.Name?.Split(' ').First() ?? "User"; }
                                    @if (!string.IsNullOrEmpty(post.User?.Username))
                                    {
                                        @Html.ActionLink(authorName, "ViewProfile", new { username = post.User.Username }, new { @class = "q-author", onclick = "event.stopPropagation();" })
                                    }
                                    else
                                    {
                                        <span class="q-author">@authorName</span>
                                    }
                                    <span class="q-date">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    @if (post.IsEndorsed)
                                    {
                                        <span class="chip chip-amber" style="background: #FFFBEB; color: #B45309; border: 1px solid #FDE68A; font-size: 9px; padding: 2px 8px;">
                                            <i data-lucide="award" style="width:10px; height:10px;"></i> VERIFIED
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div style="display:flex; gap:20px; align-items:flex-start;">
                            <div style="flex:1;">
                                <!-- Title -->
                                <h3 class="q-title" style="margin-top:0;">@post.Title</h3>

                                <!-- Preview -->
                                @if (!string.IsNullOrEmpty(post.Content))
                                {
                                    <p class="q-content">
                                        @{
                                            var preview = post.Content.Length > 150 ? post.Content.Substring(0, 150) + "..." : post.Content;
                                        }
                                        @preview
                                    </p>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <div style="width:120px; height:80px; border-radius:8px; overflow:hidden; flex-shrink:0; border:1px solid var(--border);">
                                    <img src="@post.ImageUrl" style="width:100%; height:100%; object-fit:cover;" />
                                </div>
                            }
                        </div>

                        <!-- Tags/Category -->
                        <div class="q-tags">
                            @if (post.Category != null)
                            {
                                <span class="chip chip-indigo">@post.Category.Name</span>
                            }
                            @if (!string.IsNullOrEmpty(post.CourseCode))
                            {
                                <span class="chip chip-gray">@post.CourseCode</span>
                            }
                            @if (post.Answers?.Any(a => a.IsAccepted && !a.IsDeleted) == true)
                            {
                                <span class="chip chip-emerald" style="display:inline-flex; align-items:center; gap:4px;"><i data-lucide="check-circle-2" style="width:12px; height:12px;"></i> Solved</span>
                            }
                        </div>

                        <!-- Stats -->
                        <div class="q-stats">
                            <button class="feed-upvote-btn" data-post-id="@post.PostID"
                                    onclick="event.stopPropagation(); feedUpvote(@post.PostID, this);"
                                    style="background:none;border:none;cursor:pointer;display:inline-flex;align-items:center;gap:4px;font-size:13px;color:var(--text-2);padding:0;font-weight:600;transition:color .15s;">
                                <i data-lucide="thumbs-up" style="width:14px; height:14px;"></i>
                                <span id="feed-upvote-@(post.PostID)">@post.Upvotes</span>
                            </button>
                            <span style="display:inline-flex; align-items:center; gap:4px;"><i data-lucide="message-square" style="width:14px; height:14px;"></i> @(post.Answers?.Count(a => !a.IsDeleted) ?? 0)</span>
                            <span style="display:inline-flex; align-items:center; gap:4px;"><i data-lucide="eye" style="width:14px; height:14px;"></i> @post.ViewsCount</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i data-lucide="file-question" style="width:48px; height:48px;"></i></div>
                    <h3 class="empty-title">No questions yet</h3>
                    <p class="empty-text">Be the first to ask a question in your community!</p>
                    <a asp-action="CreatePost" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:8px;"><i data-lucide="pencil-line" style="width:18px; height:18px;"></i> Ask a Question</a>
                </div>
            }
        }
        </div>

        <aside style="display: flex; flex-direction: column; gap: 24px; position: sticky; top: 100px;">
            <div class="glass-card p-4">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                    <h4 style="font-size: 14px; font-weight: 800; text-transform: uppercase; color: var(--indigo); letter-spacing: 0.05em;">Trending Topics</h4>
                    <i data-lucide="trending-up" style="width: 16px; height: 16px; color: var(--indigo);"></i>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    @{
                        var trendingPosts = (ViewBag.Posts as List<Post>)?.OrderByDescending(p => p.ViewsCount + p.Upvotes).Take(5).ToList();
                        if (trendingPosts != null && trendingPosts.Any())
                        {
                            int rank = 1;
                            foreach(var tp in trendingPosts)
                            {
                                <a href="@Url.Action("SinglePost", new { id = tp.PostID })" class="trending-item">
                                    <span class="trending-rank">#@rank</span>
                                    <div class="trending-info">
                                        <div class="trending-title">@tp.Title</div>
                                        <div class="trending-meta">@tp.ViewsCount views • @(tp.Answers?.Count ?? 0) answers</div>
                                    </div>
                                </a>
                                rank++;
                            }
                        }
                    }
                </div>
            </div>

            <div class="glass-card p-4" style="background: linear-gradient(135deg, var(--indigo), var(--violet)); color: #fff; border: none;">
                <h4 style="font-size: 13px; font-weight: 700; opacity: 0.9; margin-bottom: 12px;">COMMUNITY STATS</h4>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <div>
                        <div style="font-size: 20px; font-weight: 800;">@(ViewBag.Posts?.Count ?? 0)</div>
                        <div style="font-size: 11px; opacity: 0.8;">Active Questions</div>
                    </div>
                    <div>
                        <div style="font-size: 20px; font-weight: 800;">@Model.Points</div>
                        <div style="font-size: 11px; opacity: 0.8;">Your Points</div>
                    </div>
                </div>
                <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.1);">
                    <a asp-action="Leaderboard" style="font-size: 12px; font-weight: 700; color: #fff; text-decoration: none; display: flex; align-items: center; gap: 4px;">
                        View Leaderboard <i data-lucide="chevron-right" style="width: 14px; height: 14px;"></i>
                    </a>
                </div>
            </div>
        </aside>
    </div>
</div>

<!-- Hidden CSRF form for AJAX upvote -->
<form id="dashCsrf" style="display:none;">@Html.AntiForgeryToken()</form>

@section Scripts {
<script>
    async function feedUpvote(postId, btn) {
        const token = document.querySelector('#dashCsrf input[name="__RequestVerificationToken"]')?.value;
        try {
            const resp = await fetch('@Url.Action("UpvotePost","Dashboard")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'postId=' + encodeURIComponent(postId)
            });
            if (resp.ok) {
                const data = await resp.json();
                const count = document.getElementById('feed-upvote-' + postId);
                if (count) count.textContent = data.upvotes;
                btn.style.color = 'var(--indigo)';
                btn.disabled = true;
                if (typeof showToast === 'function') showToast('Upvoted! +1', 'success');
            } else if (resp.status === 400) {
                btn.style.color = 'var(--indigo)';
                btn.disabled = true;
                if (typeof showToast === 'function') showToast('Already upvoted', 'warn');
            }
        } catch (err) {
            console.error(err);
        }
    }
</script>
}