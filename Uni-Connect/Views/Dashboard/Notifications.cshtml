@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "Notifications — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
    .notif-wrapper { max-width: 800px; margin: 0 auto; }
    
    .notif-header { margin-bottom: 28px; }
    .notif-title { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
    .notif-subtitle { font-size: 14px; color: var(--text-2); }
    
    .notif-container { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    
    .notif-item {
        display: flex; gap: 16px; padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        transition: background .2s;
        cursor: pointer;
    }
    .notif-item:last-child { border-bottom: none; }
    .notif-item:hover { background: var(--bg); }
    
    .notif-icon {
        font-size: 20px; flex-shrink: 0;
        margin-top: 2px;
    }
    
    .notif-content { flex: 1; }
    .notif-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
    .notif-time { font-size: 12px; color: var(--text-2); }
    
    .empty-notif {
        text-align: center; padding: 60px 30px;
    }
    .empty-icon { font-size: 48px; margin-bottom: 16px; }
    .empty-title { font-size: 16px; font-weight: 700; margin-bottom: 6px; color: var(--text); }
    .empty-text { font-size: 13px; color: var(--text-2); }
</style>
} 

<div class="notif-wrapper">
    <!-- Page Header -->
    <div class="notif-header">
        <h1 class="notif-title">🔔 Notifications</h1>
        <p class="notif-subtitle">Stay updated with your activity and discussions</p>
    </div>

    <!-- Notifications List -->
    @if (Model?.Notifications?.Any() == true)
    {
        <div class="notif-container">
            @foreach (var notif in Model.Notifications.OrderByDescending(n => n.CreatedAt))
            {
                var (icon, color) = notif.Type switch
                {
                    "Answer" => ("💬", "var(--indigo)"),
                    "PostUpvote" => ("🔥", "var(--rose)"),
                    "Upvote" => ("👍", "var(--amber)"),
                    "BestAnswer" => ("⭐", "var(--emerald)"),
                    "SessionAccepted" => ("✅", "var(--emerald)"),
                    "TutoringRequest" => ("🎓", "var(--indigo)"),
                    _ => ("🔔", "var(--text-2)")
                };

                var message = notif.Type switch
                {
                    "Answer" => "Someone answered your question",
                    "PostUpvote" => "Someone upvoted your question",
                    "Upvote" => "Someone upvoted your post",
                    "BestAnswer" => "Your answer was marked as best!",
                    "SessionAccepted" => "Your tutoring session request was accepted",
                    "TutoringRequest" => "A peer wants to tutor you privately — go to Sessions to accept",
                    _ => $"{notif.Type} notification"
                };

                var url = notif.Type switch
                {
                    "Answer" or "PostUpvote" or "Upvote" or "BestAnswer" => Url.Action("SinglePost", "Dashboard", new { id = notif.ReferenceID }),
                    "SessionAccepted" or "TutoringRequest" => Url.Action("Sessions", "Dashboard"),
                    _ => "#"
                };

                <a href="@url" style="text-decoration: none; color: inherit; display: block;">
                    <div class="notif-item">
                        <div class="notif-icon" style="color: @color">@icon</div>
                        <div class="notif-content">
                            <div class="notif-title">@message</div>
                            <div class="notif-time">@notif.CreatedAt.ToString("MMMM d, yyyy · h:mm tt")</div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="notif-container">
            <div class="empty-notif">
                <div class="empty-icon">🧘</div>
                <h3 class="empty-title">All caught up!</h3>
                <p class="empty-text">You don't have any new notifications right now</p>
            </div>
        </div>
    }
</div>
