@model PointsViewModel

@{
    ViewData["Title"] = "Points & Rewards";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
    /* Tabs styling */
    .tabs {
        display: flex;
        gap: 2px;
        border-bottom: 2px solid var(--border);
        margin-bottom: 24px;
        overflow-x: auto;
    }
    .tabs::-webkit-scrollbar { height: 0; }
    .tab {
        padding: 12px 20px;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-2);
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        border-radius: 8px 8px 0 0;
        transition: all 0.2s;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .tab:hover { color: var(--indigo); background: var(--indigo-light); }
    .tab.active { color: var(--indigo); border-bottom-color: var(--indigo); }

    /* Hero Card */
    .points-hero {
        background: linear-gradient(135deg, var(--indigo), #5B73C7 50%, var(--violet));
        border-radius: 20px;
        padding: 32px;
        color: #fff;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
        position: relative;
        overflow: hidden;
    }
    .points-hero-icon {
        position: absolute;
        right: -20px;
        bottom: -20px;
        font-size: 110px;
        opacity: .08;
        pointer-events: none;
    }

    /* Venues Grid */
    .venues-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
    }
    .venue-card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: all .25s;
        cursor: pointer;
        display: flex;
        flex-direction: column;
    }
    .venue-card:hover:not(.locked) {
        box-shadow: var(--shadow-md);
        transform: translateY(-3px);
        border-color: var(--indigo);
    }
    .venue-card.locked { opacity: .55; cursor: not-allowed; }
    .venue-img {
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 52px;
        position: relative;
    }
    .venue-off {
        position: absolute;
        top: 10px;
        right: 10px;
        background: var(--rose);
        color: #fff;
        border-radius: 99px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 800;
    }
    .venue-body { padding: 18px; flex: 1; display: flex; flex-direction: column; }
    .venue-name { font-weight: 800; font-size: 16px; margin-bottom: 6px; }
    .venue-desc { font-size: 13px; color: var(--text-2); margin-bottom: 16px; line-height: 1.5; flex: 1; }
    .venue-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
    .venue-pts { font-size: 14px; font-weight: 800; color: var(--amber); }

    /* Modal Styling */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, .55);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(6px);
        opacity: 0;
        visibility: hidden;
        transition: all 0.25s;
    }
    .modal-overlay.open { opacity: 1; visibility: visible; }
    .modal-box {
        background: #fff;
        border-radius: 20px;
        padding: 30px;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 24px 64px rgba(61, 82, 160, .22);
        transform: scale(0.9);
        transition: transform 0.25s;
    }
    .modal-overlay.open .modal-box { transform: scale(1); }

    /* Hidden utilities */
    .hidden { display: none !important; }
    .fade-in { animation: fadeIn 0.3s ease; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
</style>
}

<div class="points-hero">
    <div class="points-hero-icon"><i data-lucide="coins"></i></div>
    <div style="z-index: 1;">
        <div style="font-size:13px; opacity:.75; margin-bottom:6px; font-weight:600">Your Current Balance</div>
        <div style="font-size:52px; font-weight:900; line-height:1; letter-spacing:-1px; display:flex; align-items:center; gap:12px;">@Model.CurrentPoints <i data-lucide="coins" style="width:32px; height:32px;"></i></div>
        <div style="margin-top:12px; font-size:13px; opacity:.85">
            <strong>Level @Model.CurrentLevel</strong> — @Model.NextLevelPoints pts to Level @(Model.CurrentLevel + 1)
        </div>
        <div style="background:rgba(255,255,255,.25); border-radius:99px; height:7px; width:240px; margin-top:8px; overflow:hidden">
            <div style="width:@Model.ProgressPercentage%; height:100%; background:#fff; border-radius:99px"></div>
        </div>
    </div>
    <div style="display:flex; gap:14px; flex-wrap:wrap; z-index: 1;">
        <div style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.2); border-radius:14px; padding:14px 20px; text-align:center; min-width:100px;">
            <div style="font-size:24px; font-weight:900">@Model.QuestionsAsked</div>
            <div style="font-size:11px; opacity:.8; margin-top:2px">Questions</div>
        </div>
        <div style="background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.2); border-radius:14px; padding:14px 20px; text-align:center; min-width:100px;">
            <div style="font-size:24px; font-weight:900">@Model.AnswersGiven</div>
            <div style="font-size:11px; opacity:.8; margin-top:2px">Answers</div>
        </div>
    </div>
</div>

<!-- TABS -->
<div class="tabs">
    <div class="tab active" onclick="showTab('tab-venues', this)"><i data-lucide="store"></i> Redeem at Venues</div>
    <div class="tab" onclick="showTab('tab-earn', this)"><i data-lucide="trending-up"></i> How to Earn</div>
    <div class="tab" onclick="showTab('tab-history', this)"><i data-lucide="clock"></i> Transactions</div>
    <div class="tab" onclick="showTab('tab-achievements', this)"><i data-lucide="award"></i> Achievements</div>
</div>

<div id="tab-container">
    <!-- ── VENUES TAB ── -->
    <div id="tab-venues" class="tab-content fade-in">
        <div style="margin-bottom:20px;">
            <h2 style="font-size:18px; font-weight:800">Redeem at Campus Venues</h2>
            <p style="font-size:13px; color:var(--text-2); margin-top:4px">Choose a discount — a QR code will be sent to your university email instantly</p>
        </div>

        <div class="venues-grid">
            <!-- Cafeteria -->
            <div class="venue-card" onclick="openRedeemModal('University Cafeteria', '☕', '10% OFF discount on any meal', 200, 'Main Building, Ground Floor')">
                <div class="venue-img" style="background:linear-gradient(135deg,#FEF9C3,#FDE68A)">☕<div class="venue-off">10% OFF</div></div>
                <div class="venue-body">
                    <div class="venue-name">University Cafeteria</div>
                    <div class="venue-desc">Valid for all drinks, snacks, and full meals. Single-use voucher.</div>
                    <div class="venue-footer">
                        <div class="venue-pts">🪙 200 pts</div>
                        <button class="btn btn-amber btn-sm">Redeem</button>
                    </div>
                </div>
            </div>

            <!-- Library -->
            <div class="venue-card" onclick="openRedeemModal('University Library', '📚', '5 JD Printing Credit', 400, 'Library Building, Level 2')">
                <div class="venue-img" style="background:linear-gradient(135deg,#EEF2FF,#C7D7FF)">📚<div class="venue-off">5 JD OFF</div></div>
                <div class="venue-body">
                    <div class="venue-name">University Library</div>
                    <div class="venue-desc">Use for printing, scanning, or study room bookings. Valid for 30 days.</div>
                    <div class="venue-footer">
                        <div class="venue-pts">🪙 400 pts</div>
                        <button class="btn btn-primary btn-sm">Redeem</button>
                    </div>
                </div>
            </div>

            <!-- Bookshop -->
            <div class="venue-card" onclick="openRedeemModal('Campus Bookshop', '📖', '15% OFF Stationery', 350, 'Student Centre, Level 1')">
                <div class="venue-img" style="background:linear-gradient(135deg,#D1FAE5,#A7F3D0)">📖<div class="venue-off">15% OFF</div></div>
                <div class="venue-body">
                    <div class="venue-name">Campus Bookshop</div>
                    <div class="venue-desc">15% discount on all stationery and university merchandise.</div>
                    <div class="venue-footer">
                        <div class="venue-pts">🪙 350 pts</div>
                        <button class="btn btn-emerald btn-sm">Redeem</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── EARN TAB ── -->
    <div id="tab-earn" class="tab-content hidden fade-in">
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 24px;">
            <div>
                <h3 style="font-size:16px; font-weight:800; margin-bottom:12px; display:flex; align-items:center; gap:8px;"><i data-lucide="trending-up" class="text-emerald"></i> Ways to Earn Points</h3>
                <div class="card" style="padding:0; overflow:hidden;">
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div><strong>Answer a Question</strong><br/><small style="color:var(--text-2)">Help a fellow student</small></div>
                        <span class="chip chip-emerald">+5 pts</span>
                    </div>
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div><strong>Get an Upvote</strong><br/><small style="color:var(--text-2)">Per upvote on your answer</small></div>
                        <span class="chip chip-emerald">+10 pts</span>
                    </div>
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center;">
                        <div><strong>Best Answer Selected</strong><br/><small style="color:var(--text-2)">Earn bonus for high quality</small></div>
                        <span class="chip chip-emerald">+15 pts</span>
                    </div>
                </div>
            </div>
            <div>
                <h3 style="font-size:16px; font-weight:800; margin-bottom:12px; display:flex; align-items:center; gap:8px;"><i data-lucide="trending-down" class="text-rose"></i> Points Decisions</h3>
                <div class="card" style="padding:0; overflow:hidden;">
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div><strong>Post a Question</strong><br/><small style="color:var(--text-2)">Encourages searching first</small></div>
                        <span class="chip chip-rose">−10 pts</span>
                    </div>
                    <div style="padding:14px; display:flex; justify-content:space-between; align-items:center;">
                        <div><strong>Request Tutoring Session</strong><br/><small style="color:var(--text-2)">Per private request</small></div>
                        <span class="chip chip-rose">−5 pts</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── HISTORY TAB ── -->
    <div id="tab-history" class="tab-content hidden fade-in">
        <div class="card" style="padding:0; overflow:hidden;">
            @if (Model.Transactions == null || !Model.Transactions.Any())
            {
                <div style="padding:40px; text-align:center; color:var(--text-2)">No transaction history yet.</div>
            }
            else
            {
                @foreach (var tx in Model.Transactions)
                {
                    <div style="padding:16px 20px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border)">
                        <div style="display:flex; align-items:center; gap:16px;">
                            <span style="font-size:20px;">@tx.Icon</span>
                            <div>
                                <div style="font-weight:700; font-size:14px;">@tx.Title</div>
                                <div style="font-size:12px; color:var(--text-2);">@tx.Time · @tx.Detail</div>
                            </div>
                        </div>
                        <span style="font-weight:800; color:@(tx.Amount >= 0 ? "var(--emerald)" : "var(--rose)")">
                            @(tx.Amount >= 0 ? "+" : "")@tx.Amount
                        </span>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ── ACHIEVEMENTS TAB ── -->
    <div id="tab-achievements" class="tab-content hidden fade-in">
        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 16px;">
            @foreach (var achievement in Model.Achievements)
            {
                <div class="card @(achievement.Unlocked ? "" : "locked")" style="text-align:center; @(achievement.Unlocked ? "background:var(--amber-light); border-color:var(--amber);" : "")">
                    <div style="font-size:32px; margin-bottom:10px; display:flex; justify-content:center;"><i data-lucide="medal" style="width:40px; height:40px;"></i></div>
                    <div style="font-weight:700; font-size:13px; margin-bottom:4px;">@achievement.Title</div>
                    <div style="font-size:11px; color:var(--text-2);">@achievement.Description</div>
                    @if (achievement.Unlocked)
                    {
                        <div style="font-size:10px; color:var(--amber-dark); margin-top:8px; font-weight:700;">✓ UNLOCKED</div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- REDEEM MODAL -->
<div class="modal-overlay" id="redeemModal">
    <div class="modal-box">
        <div style="text-align:center; margin-bottom:24px;">
            <div id="modalIcon" style="font-size:64px; margin-bottom:12px;">☕</div>
            <h3 id="modalTitle" style="font-size:20px; font-weight:900;">Venue Name</h3>
            <p id="modalDesc" style="font-size:14px; color:var(--text-2);">Discount description goes here.</p>
            <div id="modalLoc" style="font-size:12px; color:var(--text-3); margin-top:8px;">📍 Location Info</div>
        </div>
        <div id="modalConfirmState">
            <div style="background:var(--indigo-light); border:1.5px solid #C7D7FF; border-radius:14px; padding:20px; text-align:center; margin-bottom:24px;">
                <div style="font-size:13px; color:var(--text-2); margin-bottom:4px;">This will cost</div>
                <div id="modalCost" style="font-size:32px; font-weight:900; color:var(--indigo);">200 pts</div>
                <div style="font-size:12px; color:var(--text-2); margin-top:6px;">Your current balance: <strong>@Model.CurrentPoints pts</strong></div>
            </div>
            <div style="display:flex; gap:12px;">
                <button class="btn btn-ghost btn-full" onclick="closeRedeemModal()">Cancel</button>
                <button class="btn btn-primary btn-full" onclick="confirmRedeem()">Confirm Redeem</button>
            </div>
        </div>
        
        <!-- SUCCESS STATE -->
        <div id="modalSuccessState" class="hidden">
            <div style="background:var(--emerald-light); border:1.5px solid var(--emerald); border-radius:14px; padding:24px; text-align:center; margin-bottom:24px;">
                <div style="font-size:13px; color:#065F46; font-weight:700; margin-bottom:12px;">SUCCESS! YOUR CODE IS:</div>
                <div id="couponCode" style="font-size:28px; font-weight:900; color:#065F46; letter-spacing:2px; font-family:monospace; background:white; padding:10px; border-radius:8px; border:2px dashed var(--emerald);">PU-XXXXXXX</div>
                <div style="font-size:11px; color:#065F46; margin-top:12px;">Screenshot this or check your history tab later.</div>
            </div>
            <button class="btn btn-emerald btn-full" onclick="location.reload()">Great, Got it!</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showTab(id, el) {
        // Update tabs
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');

        // Update content
        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        document.getElementById(id).classList.remove('hidden');
    }

    function openRedeemModal(name, icon, desc, cost, loc) {
        document.getElementById('modalTitle').textContent = name;
        document.getElementById('modalIcon').textContent = icon;
        document.getElementById('modalDesc').textContent = desc;
        document.getElementById('modalCost').textContent = cost + " pts";
        document.getElementById('modalLoc').textContent = "📍 " + loc;
        
        const modal = document.getElementById('redeemModal');
        modal.classList.add('open');
        document.getElementById('modalConfirmState').classList.remove('hidden');
        document.getElementById('modalSuccessState').classList.add('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeRedeemModal() {
        const modal = document.getElementById('redeemModal');
        modal.classList.remove('open');
        document.body.style.overflow = '';
    }

    async function confirmRedeem() {
        const btn = document.querySelector('.modal-box .btn-primary');
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = "Processing...";

        const venue = document.getElementById('modalTitle').textContent;
        const discount = document.getElementById('modalDesc').textContent;
        const costStr = document.getElementById('modalCost').textContent;
        const cost = parseInt(costStr);

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const resp = await fetch('@Url.Action("RedeemReward", "Dashboard")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: `venue=${encodeURIComponent(venue)}&discount=${encodeURIComponent(discount)}&cost=${cost}&__RequestVerificationToken=${token}`
            });

            const result = await resp.json();
            if (result.success) {
                document.getElementById('modalConfirmState').classList.add('hidden');
                document.getElementById('modalSuccessState').classList.remove('hidden');
                document.getElementById('couponCode').textContent = result.couponCode;
                
                showToast("🎉 Reward redeemed successfully!");
                // Update UI balance if possible
                const balanceElements = document.querySelectorAll('[id*="Points"], [id*="ptWidget"]');
                balanceElements.forEach(el => {
                    if (el.id !== 'sidebarPoints' && el.id !== 'ptWidget') {
                         el.textContent = result.pointsBalance;
                    }
                });
                // Trigger global stats update
                if (typeof updateStats === 'function') updateStats();
                
                closeRedeemModal();
            } else {
                showToast(result.message || "Redemption failed.", "error");
            }
        } catch (err) {
            console.error(err);
            showToast("Failed to connect to server.", "error");
        } finally {
            btn.disabled = false;
            btn.textContent = originalText;
        }
    }

    // Close modal on escape
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeRedeemModal();
    });
</script>
}
@Html.AntiForgeryToken()
