@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "My Profile — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
    .profile-wrapper { max-width: 1000px; margin: 0 auto; }
    
    .profile-cover {
        height: 180px; border-radius: 16px; overflow: hidden;
        position: relative; margin-bottom: 60px;
        background: linear-gradient(135deg, var(--indigo-light) 0%, var(--violet-light) 100%);
    }
    .profile-cover-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(180deg, transparent 40%, rgba(61,82,160,.2));
    }
    
    .profile-avatar-wrap {
        position: absolute; bottom: -50px; left: 24px;
    }
    .profile-avatar {
        width: 120px; height: 120px; border-radius: 16px;
        border: 4px solid var(--surface); overflow: hidden;
        box-shadow: 0 4px 16px rgba(15,23,42,.15);
    }
    .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
    
    .profile-header {
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 16px;
        margin-bottom: 24px; flex-wrap: wrap;
    }
    
    .profile-info h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; }
    .profile-badges {
        display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px;
    }
    .profile-bio {
        font-size: 14px; color: var(--text-2);
        line-height: 1.6; max-width: 600px; margin-top: 8px;
    }
    
    .profile-actions { display: flex; gap: 8px; }
    
    .profile-stats {
        display: grid; grid-template-columns: repeat(5, 1fr);
        gap: 12px; margin-bottom: 28px;
    }
    @@media (max-width: 768px) {
        .profile-stats { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 480px) {
        .profile-stats { grid-template-columns: repeat(2, 1fr); }
    }
    
    .stat-item {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 16px;
        text-align: center;
    }
    .stat-num {
        font-size: 20px; font-weight: 800;
        margin-bottom: 4px;
    }
    .stat-label {
        font-size: 11px; font-weight: 700;
        color: var(--text-2); text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .progress-section {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 20px;
        margin-bottom: 28px; display: flex;
        align-items: center; gap: 20px; flex-wrap: wrap;
    }
    .progress-content { flex: 1; min-width: 200px; }
    .progress-label {
        font-size: 13px; font-weight: 700;
        color: var(--text); margin-bottom: 8px;
        display: flex; justify-content: space-between;
    }
    .progress-bar {
        height: 8px; background: var(--border);
        border-radius: 99px; overflow: hidden;
    }
    .progress-fill {
        height: 100%; background: linear-gradient(90deg, var(--indigo), var(--violet));
        transition: width .3s ease;
    }
    .progress-text {
        font-size: 12px; color: var(--text-2);
        margin-top: 6px;
    }
    
    .tabs {
        display: flex; gap: 16px; border-bottom: 2px solid var(--border);
        margin-bottom: 24px; flex-wrap: wrap;
    }
    .tab {
        padding: 12px 0; background: none; border: none;
        font-size: 14px; font-weight: 600; color: var(--text-2);
        cursor: pointer; border-bottom: 3px solid transparent;
        margin-bottom: -2px; transition: all .2s;
    }
    .tab:hover { color: var(--indigo); }
    .tab.active {
        color: var(--indigo); font-weight: 700;
        border-bottom-color: var(--indigo);
    }
    
    .activity-list { display: flex; flex-direction: column; gap: 14px; }
    
    .activity-card {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 18px;
        cursor: pointer; transition: all .2s;
    }
    .activity-card:hover {
        box-shadow: var(--shadow-md); transform: translateY(-1px);
    }
    
    .activity-meta {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 10px; flex-wrap: wrap;
        font-size: 12px; color: var(--text-2);
    }
    
    .activity-title {
        font-size: 14px; font-weight: 700;
        margin-bottom: 8px; line-height: 1.4; color: var(--text);
    }
    
    .activity-stats {
        display: flex; gap: 16px; font-size: 12px;
        color: var(--text-2); font-weight: 600;
    }
</style>
}

<div class="profile-wrapper">
    <!-- Profile Cover -->
    <div class="profile-cover">
        <div class="profile-cover-overlay"></div>
        <div class="profile-avatar-wrap">
            <div class="profile-avatar">
                <img src="https://ui-avatars.com/api/?name=@Model.Name&background=3D52A0&color=fff&size=120" alt="@Model.Name" />
            </div>
        </div>
    </div>

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-info">
            <h1>@Model.Name</h1>
            <div class="profile-badges">
                <span class="chip chip-indigo" style="display:inline-flex; align-items:center; gap:6px;"><i data-lucide="building-2" style="width:14px; height:14px;"></i> @Model.Faculty</span>
                <span class="chip chip-violet" style="display:inline-flex; align-items:center; gap:6px;"><i data-lucide="graduation-cap" style="width:14px; height:14px;"></i> @Model.YearOfStudy</span>
                <span class="chip chip-amber" style="display:inline-flex; align-items:center; gap:6px;"><i data-lucide="coins" style="width:14px; height:14px;"></i> @Model.Points pts</span>
            </div>
            <p class="profile-bio">
                Dedicated Philadelphia University student passionate about problem-solving and collaboration. Always happy to help fellow students! 🚀
            </p>
        </div>
        <div class="profile-actions">
            <button type="button" class="btn btn-ghost btn-sm" onclick="switchTab('settings', document.querySelector('[onclick*=\'settings\']'))" style="display:inline-flex; align-items:center; gap:8px;"><i data-lucide="edit-3" style="width:16px; height:16px;"></i> Edit Profile</button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="profile-stats">
        <div class="stat-item">
            <div class="stat-num" style="color: var(--indigo)">@Model.Points</div>
            <div class="stat-label">🪙 Points</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" style="color: var(--emerald)">@Model.Answers.Count</div>
            <div class="stat-label">💬 Answers</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" style="color: var(--amber)">@Model.Posts.Count</div>
            <div class="stat-label">❓ Questions</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" style="color: var(--violet)">@ViewBag.SessionCount</div>
            <div class="stat-label">🎓 Sessions</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" style="color: var(--rose)">@(Model.Points / 500 + 1)</div>
            <div class="stat-label">⭐ Level</div>
        </div>
    </div>

    <!-- Progress to Tutor -->
    <div class="progress-section">
        <div class="progress-content">
            <div class="progress-label">
                <span>Progress to <strong>Verified Tutor</strong></span>
                <span>@Model.Points / 1000 pts</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: @(Math.Min((Model.Points / 10), 100))%"></div>
            </div>
            <div class="progress-text">@(1000 - Model.Points) pts to go! Level up to unlock tutor badge.</div>
        </div>
        <a asp-action="Points" class="btn btn-amber btn-sm">View Rewards →</a>
    </div>

    <!-- Activity Tabs -->
    <div class="tabs">
        <button class="tab active" onclick="switchTab('answers',this)" style="display:inline-flex; align-items:center; gap:8px;"><i data-lucide="message-square" style="width:16px; height:16px;"></i> Recent Answers</button>
        <button class="tab" onclick="switchTab('questions',this)" style="display:inline-flex; align-items:center; gap:8px;"><i data-lucide="help-circle" style="width:16px; height:16px;"></i> Your Questions</button>
        <button class="tab" onclick="switchTab('settings',this)" style="display:inline-flex; align-items:center; gap:8px;"><i data-lucide="settings" style="width:16px; height:16px;"></i> Settings</button>
    </div>

    <!-- Tab Content: Answers -->
    <div id="tab-answers">
        <div class="activity-list">
            @if (Model.Answers != null && Model.Answers.Any())
            {
                foreach (var answer in Model.Answers.OrderByDescending(a => a.CreatedAt).Take(5))
                {
                    <div class="activity-card" onclick="window.location.href='@Url.Action("SinglePost", new { id = answer.PostID })'">
                        <div class="activity-meta">
                            @if (answer.IsAccepted) { <span class="chip chip-emerald">✓ Best Answer</span> }
                            <span class="chip chip-violet">@answer.Post?.Title.Substring(0, Math.Min(answer.Post.Title.Length, 15))...</span>
                            <span>👍 @answer.Upvotes upvotes</span>
                        </div>
                        <div class="activity-title">@answer.Content.Substring(0, Math.Min(answer.Content.Length, 100))...</div>
                        <div class="activity-stats">
                            <span>📅 @answer.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="text-align:center; color:var(--text-2); padding:20px;">No answers yet.</p>
            }
        </div>
    </div>

    <!-- Tab Content: Questions (Hidden) -->
    <div id="tab-questions" class="hidden">
        <div class="activity-list">
            @if (Model.Posts != null && Model.Posts.Any())
            {
                foreach (var post in Model.Posts.OrderByDescending(p => p.CreatedAt).Take(5))
                {
                    <div class="activity-card" onclick="window.location.href='@Url.Action("SinglePost", new { id = post.PostID })'">
                        <div class="activity-meta">
                            @if (post.Answers != null && post.Answers.Any(a => a.IsAccepted)) { <span class="chip chip-emerald">✓ Solved</span> }
                            <span class="chip chip-indigo">@post.Category?.Name</span>
                        </div>
                        <div class="activity-title">@post.Title</div>
                        <div class="activity-stats">
                            <span>👍 @post.Upvotes upvotes</span>
                            <span>💬 @(post.Answers?.Count ?? 0) answers</span>
                            <span>👁️ @post.ViewsCount views</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="text-align:center; color:var(--text-2); padding:20px;">No questions asked yet.</p>
            }
        </div>
    </div>

    <!-- Tab Content: Sessions (Hidden) -->
    <div id="tab-settings" class="hidden">
        @{
            var settingsModel = ViewBag.SettingsModel as Uni_Connect.ViewModels.SettingsViewModel;
        }
        @if (settingsModel != null)
        {
            <form asp-action="Settings" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserID" value="@settingsModel.UserID" />
                <div class="card" style="background: white; border: 1.5px solid var(--border); border-radius: 12px; padding: 24px;">
                    <div style="font-weight: 800; font-size: 18px; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 12px;">
                        <i data-lucide="circle-user" style="vertical-align: middle; margin-right: 8px;"></i> Profile Information
                    </div>
                    
                    <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px;">
                        <div class="av av-xl" style="border:4px solid var(--indigo-light)">
                            <img id="profilePreview" src="@(string.IsNullOrEmpty(settingsModel.ProfileImageUrl) ? $"https://ui-avatars.com/api/?name={settingsModel.Name}&background=3D52A0&color=fff&size=80" : settingsModel.ProfileImageUrl)" alt="Avatar"/>
                        </div>
                        <div>
                            <button type="button" class="btn btn-ghost btn-sm" onclick="promptImageUrl()">Change Photo</button>
                            <p style="font-size:11px; color:var(--text-2); margin-top:6px;">Paste an image URL to update your profile picture.</p>
                        </div>
                        <input type="hidden" name="ProfileImageUrl" id="hiddenImageUrl" value="@settingsModel.ProfileImageUrl" />
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div class="form-group">
                            <label class="form-label">Full Name</label>
                            <input name="Name" value="@settingsModel.Name" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email (Private)</label>
                            <input value="@settingsModel.Email" class="form-input" disabled />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Faculty</label>
                            <select name="Faculty" class="form-input form-select">
                                <option value="Faculty of Information Technology" selected="@(settingsModel.Faculty == "Faculty of Information Technology")">Faculty of Information Technology</option>
                                <option value="Faculty of Engineering" selected="@(settingsModel.Faculty == "Faculty of Engineering")">Faculty of Engineering</option>
                                <option value="Faculty of Business" selected="@(settingsModel.Faculty == "Faculty of Business")">Faculty of Business</option>
                                <option value="Faculty of Law" selected="@(settingsModel.Faculty == "Faculty of Law")">Faculty of Law</option>
                                <option value="Faculty of Pharmacy" selected="@(settingsModel.Faculty == "Faculty of Pharmacy")">Faculty of Pharmacy</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Year</label>
                            <select name="YearOfStudy" class="form-input form-select">
                                <option value="Year 1" selected="@(settingsModel.YearOfStudy == "Year 1")">Year 1</option>
                                <option value="Year 2" selected="@(settingsModel.YearOfStudy == "Year 2")">Year 2</option>
                                <option value="Year 3" selected="@(settingsModel.YearOfStudy == "Year 3")">Year 3</option>
                                <option value="Year 4" selected="@(settingsModel.YearOfStudy == "Year 4")">Year 4</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>

                <div class="card" style="background: white; border: 1.5px solid var(--border); border-radius: 12px; padding: 24px; margin-top: 20px;">
                    <div style="font-weight: 800; font-size: 18px; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 12px;">
                        <i data-lucide="shield-check" style="vertical-align: middle; margin-right: 8px;"></i> Security
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="form-group">
                            <label class="form-label">New Password</label>
                            <input name="NewPassword" type="password" class="form-input" placeholder="Leave blank to keep current" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Current Password</label>
                            <input name="CurrentPassword" type="password" class="form-input" placeholder="Required for changes" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="margin-top: 20px;">Update Password</button>
                </div>
            </form>
        }
    </div>
</div>

<script>
    function switchTab(tabName, el) {
        // Hide all tabs
        ['answers', 'questions', 'settings'].forEach(t => {
            const tab = document.getElementById('tab-' + t);
            if (tab) tab.classList.add('hidden');
        });
        
        // Show selected tab
        const selected = document.getElementById('tab-' + tabName);
        if (selected) selected.classList.remove('hidden');
        
        // Update active tab button
        document.querySelectorAll('.tab').forEach(btn => btn.classList.remove('active'));
        if (el) el.classList.add('active');
    }

    function promptImageUrl() {
        const url = prompt("Please enter the URL of your profile image:");
        if (url && url.length > 10) {
            document.getElementById('hiddenImageUrl').value = url;
            document.getElementById('profilePreview').src = url;
            showToast("Profile image URL updated!", "success");
        }
    }
</script>