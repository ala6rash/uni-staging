@model Uni_Connect.ViewModels.SettingsViewModel

@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
    .settings-container {
        max-width: 800px;
        margin: 0 auto;
    }
    .card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 14px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-sm);
    }
    .card-title {
        font-size: 18px;
        font-weight: 800;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
    }
    .settings-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
        gap: 20px;
    }
    .settings-row:last-child { border-bottom: none; }
    .settings-row-info { flex: 1; }
    .settings-row-label { font-weight: 700; font-size: 14px; margin-bottom: 4px; }
    .settings-row-sub { font-size: 12px; color: var(--text-2); }

    .danger-card { border-color: var(--rose-light); }
    .danger-title { color: var(--rose); border-bottom-color: var(--rose-light); }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    @@media (max-width: 600px) {
        .form-grid { grid-template-columns: 1fr; }
    }
</style>
}

<div class="settings-container">
    <div style="margin-bottom:28px">
        <h1 style="font-size:28px; font-weight:900; display:flex; align-items:center; gap:12px;"><i data-lucide="settings" style="width:32px; height:32px; color:var(--text-2);"></i> Settings</h1>
        <p style="color:var(--text-2); font-size:14px; margin-top:4px">Manage your account and security preferences</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:var(--emerald-light); color:#065F46; padding:12px 16px; border-radius:10px; margin-bottom:24px; font-size:14px; font-weight:600; display:flex; align-items:center; gap:8px;">
            <i data-lucide="check-circle" style="width:18px; height:18px;"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:var(--rose-light); color:#9F1239; padding:12px 16px; border-radius:10px; margin-bottom:24px; font-size:14px; font-weight:600; display:flex; align-items:center; gap:8px;">
            <i data-lucide="x-circle" style="width:18px; height:18px;"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="Settings" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserID" />

        <!-- Profile Section -->
        <div class="card">
            <div class="card-title"><i data-lucide="circle-user" style="width:20px; height:20px;"></i> Profile Information</div>
            
            <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px;">
                <div class="av av-xl" style="border:4px solid var(--indigo-light)">
                    <img id="profilePreview" src="@(string.IsNullOrEmpty(Model.ProfileImageUrl) ? $"https://ui-avatars.com/api/?name={Model.Name}&background=3D52A0&color=fff&size=80" : Model.ProfileImageUrl)" alt="Avatar"/>
                </div>
                <div>
                    <button type="button" class="btn btn-ghost btn-sm" onclick="promptImageUrl()">Change Photo</button>
                    <p style="font-size:11px; color:var(--text-2); margin-top:6px;">Paste an image URL to update your profile picture.</p>
                </div>
                <input type="hidden" asp-for="ProfileImageUrl" id="hiddenImageUrl" />
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input asp-for="Name" class="form-input" placeholder="Enter your full name" />
                </div>
                <div class="form-group">
                    <label class="form-label">University Email</label>
                    <input asp-for="Email" class="form-input" disabled />
                    <span class="form-hint">Email cannot be changed</span>
                </div>
                <div class="form-group">
                    <label class="form-label">Faculty</label>
                    <select asp-for="Faculty" class="form-input form-select">
                        <option value="IT Faculty">Faculty of Information Technology</option>
                        <option value="Engineering">Faculty of Engineering</option>
                        <option value="Business">Faculty of Business</option>
                        <option value="Science">Faculty of Science</option>
                        <option value="Pharmacy">Faculty of Pharmacy</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Year of Study</label>
                    <select asp-for="YearOfStudy" class="form-input form-select">
                        <option value="1st Year">1st Year</option>
                        <option value="2nd Year">2nd Year</option>
                        <option value="3rd Year">3rd Year</option>
                        <option value="4th Year">4th Year</option>
                        <option value="Graduate">Graduate</option>
                    </select>
                </div>
            </div>
            <div style="margin-top:10px;">
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </div>

        <!-- Security Section -->
        <div class="card">
            <div class="card-title"><i data-lucide="shield-check" style="width:20px; height:20px;"></i> Security & Password</div>
            
            <div style="max-width: 500px;">
                <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <input asp-for="CurrentPassword" type="password" class="form-input" placeholder="Enter current password to verify" />
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <input asp-for="NewPassword" type="password" class="form-input" placeholder="Minimum 6 characters" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm New Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Repeat new password" />
                    </div>
                </div>
            </div>
            <div style="margin-top:10px;">
                <button type="submit" class="btn btn-primary">Update Password</button>
            </div>
        </div>
    </form>

    <!-- Notification Toggles (Mockup for now as requested) -->
    <div class="card">
        <div class="card-title"><i data-lucide="bell" style="width:20px; height:20px;"></i> Notifications</div>
        <div class="settings-row">
            <div class="settings-row-info">
                <div class="settings-row-label">Answers to my questions</div>
                <div class="settings-row-sub">Get notified when someone helps you out</div>
            </div>
            <div class="toggle-switch"><input type="checkbox" checked disabled></div>
        </div>
        <div class="settings-row">
            <div class="settings-row-info">
                <div class="settings-row-label">Session requests</div>
                <div class="settings-row-sub">Alerts for new private tutoring requests</div>
            </div>
            <div class="toggle-switch"><input type="checkbox" checked disabled></div>
        </div>
    </div>

    <!-- Danger Zone -->
    <div class="card danger-card">
        <div class="card-title danger-title"><i data-lucide="alert-triangle" style="width:20px; height:20px;"></i> Danger Zone</div>
        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
            <div>
                <div style="font-weight:700; font-size:14px; margin-bottom:4px">Delete Account</div>
                <div style="font-size:12px; color:var(--text-2)">Permanently remove your account and all data. This cannot be undone.</div>
            </div>
            <button class="btn btn-rose btn-sm" onclick="confirmDelete()">Delete Account</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function promptImageUrl() {
        const url = prompt("Please enter the URL of your profile image:");
        if (url && url.length > 10) {
            document.getElementById('hiddenImageUrl').value = url;
            document.getElementById('profilePreview').src = url;
            showToast("Profile image URL updated!", "success");
        }
    }

    function confirmDelete() {
        if (confirm("Are you absolutely sure? This will delete all your points, posts, and achievements forever.")) {
            alert("This functionality is managed by administrative requests.");
        }
    }
</script>
}
