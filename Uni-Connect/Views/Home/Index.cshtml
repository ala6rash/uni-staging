            <div class="venue" style="background:linear-gradient(135deg,#EEF2FF,#F4F6FF);border-color:#C7D7FF;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:210px;text-align:center"><div style="font-size:36px;margin-bottom:12px">➕</div><div style="font-weight:800;font-size:15px;color:#3D52A0;margin-bottom:6px">More Coming Soon</div><div style="font-size:13px;color:#64748B;padding:0 16px">New venues added every semester</div></div>
        </div>
    </div>
</section>

<!-- TESTIMONIALS -->
<section class="section features-bg">
    <div style="max-width:1100px;margin:0 auto">
        <div class="center">
            <div class="section-tag">💬 Student Stories</div>
            <h2 class="section-title">What students are saying</h2>
        </div>
