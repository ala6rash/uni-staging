        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta">
    <div style="max-width:720px;margin:0 auto">
        <div style="font-size:56px;margin-bottom:20px">🎓</div>
        <h2 style="font-size:clamp(34px,5vw,56px);font-weight:900;line-height:1.1;letter-spacing:-1.5px;margin-bottom:18px">Ready to learn smarter?</h2>
        <p style="font-size:18px;opacity:.8;line-height:1.7;margin-bottom:40px;max-width:560px;margin-left:auto;margin-right:auto">Join @ViewBag.StudentCount Philadelphia University students already helping each other, earning points, and getting real discounts across campus.</p>
