            <a asp-controller="Login" asp-action="Register_Page"><button class="btn btn-white btn-lg">Create Free Account →</button></a>
            <a asp-controller="Login" asp-action="Login_Page"><button class="btn btn-outline-white btn-lg">Sign In</button></a>
        </div>
        <div class="cta-checks">
            <span>✓ Free forever</span>
            <span>✓ University email only</span>
            <span>✓ No credit card</span>
            <span>✓ Real campus rewards</span>
        </div>
    </div>
</section>