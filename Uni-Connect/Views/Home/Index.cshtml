        <div class="venues-grid">
            <div class="venue"><div class="venue-img" style="background:linear-gradient(135deg,#FEF9C3,#FDE68A)"><i data-lucide="coffee" style="width:32px;height:32px;color:var(--amber)"></i><div class="venue-off">10% OFF</div></div><div class="venue-body"><div class="venue-name">University Cafeteria</div><div class="venue-pts">🪙 200 pts to redeem</div><div class="venue-loc">📍 Main Building, Ground Floor</div></div></div>
            <div class="venue"><div class="venue-img" style="background:linear-gradient(135deg,#EEF2FF,#C7D7FF)"><i data-lucide="book" style="width:32px;height:32px;color:var(--indigo)"></i><div class="venue-off">5 JD OFF</div></div><div class="venue-body"><div class="venue-name">University Library</div><div class="venue-pts">🪙 400 pts to redeem</div><div class="venue-loc">📍 Library Building, Level 2</div></div></div>
            <div class="venue"><div class="venue-img" style="background:linear-gradient(135deg,#D1FAE5,#A7F3D0)"><i data-lucide="book-open" style="width:32px;height:32px;color:var(--emerald)"></i><div class="venue-off">15% OFF</div></div><div class="venue-body"><div class="venue-name">Campus Bookshop</div><div class="venue-pts">🪙 350 pts to redeem</div><div class="venue-loc">📍 Student Centre, Level 1</div></div></div>
            <div class="venue"><div class="venue-img" style="background:linear-gradient(135deg,#FFE4E6,#FFC4CE)"><i data-lucide="printer" style="width:32px;height:32px;color:var(--rose)"></i><div class="venue-off">20 Pages Free</div></div><div class="venue-body"><div class="venue-name">Print & Copy Centre</div><div class="venue-pts">🪙 150 pts to redeem</div><div class="venue-loc">📍 IT Building, Room 102</div></div></div>
            <div class="venue"><div class="venue-img" style="background:linear-gradient(135deg,#E0F2FE,#BAE6FD)"><i data-lucide="cup-soda" style="width:32px;height:32px;color:#0EA5E9"></i><div class="venue-off">Free Drink</div></div><div class="venue-body"><div class="venue-name">Student Canteen</div><div class="venue-pts">🪙 180 pts to redeem</div><div class="venue-loc">📍 Engineering Building</div></div></div>
            <div class="venue"><div class="venue-img" style="background:linear-gradient(135deg,#EDE9FE,#DDD6FE)"><i data-lucide="activity" style="width:32px;height:32px;color:var(--violet)"></i><div class="venue-off">1 Week Free</div></div><div class="venue-body"><div class="venue-name">Sports & Gym Centre</div><div class="venue-pts">🪙 500 pts to redeem</div><div class="venue-loc">📍 Sports Complex</div></div></div>
