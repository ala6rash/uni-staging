@{
    ViewData["Title"] = "UniConnect — Philadelphia University Peer Learning Platform";
}

<!-- HERO -->
<section class="hero">
    <div class="hero-badge">🎓 Exclusive to Philadelphia University Students</div>
    <h1 class="hero-title">
        Help Each Other.<br>
        <span class="grad">Earn Real Rewards.</span>
    </h1>
    <p class="hero-sub">The peer-learning platform built only for Philadelphia University students. Ask questions, share knowledge, earn points — then spend them at the university cafeteria, library, bookshop and more.</p>
    <div class="hero-btns">
        <a asp-controller="Login" asp-action="Register_Page"><button class="btn btn-primary btn-lg">Get Started Free 🚀</button></a>
        <a href="#how"><button class="btn btn-ghost btn-lg">See How It Works ↓</button></a>
    </div>

    <div class="hero-stats">
        <div style="text-align:center"><div class="stat-num">@ViewBag.StudentCount@(ViewBag.StudentCount > 0 ? "+" : "")</div><div class="stat-lbl">Active Students</div></div>
        <div style="text-align:center"><div class="stat-num">@ViewBag.PostCount@(ViewBag.PostCount > 0 ? "+" : "")</div><div class="stat-lbl">Questions Asked</div></div>
        <div style="text-align:center"><div class="stat-num">@ViewBag.AnswerCount@(ViewBag.AnswerCount > 0 ? "+" : "")</div><div class="stat-lbl">Helpful Answers</div></div>
        <div style="text-align:center"><div class="stat-num">7+</div><div class="stat-lbl">Campus Venues</div></div>
    </div>

    <!-- Mock UI preview -->
    <div class="hero-mockup">
        <div class="mock">
            <div style="display:flex;align-items:center;gap:9px;margin-bottom:12px">
                <div class="av-premium av-sm"><img src="https://i.pravatar.cc/38?img=11" alt="Ahmad"></div>
                <div><div style="font-weight:700;font-size:13px">Ahmad K.</div><div style="font-size:11px;color:#64748B">2 hours ago</div></div>
                <span class="chip chip-emerald" style="margin-left:auto;font-weight:700">✅ Solved</span>
            </div>
            <div style="font-size:14px;font-weight:800;margin-bottom:10px;line-height:1.4">How does AVL tree rotation actually work?</div>
            <div style="display:flex;gap:12px;font-size:12px;color:#64748B"><span>👍 42</span><span>💬 7 answers</span><span>👁 124 views</span></div>
        </div>
        <div class="mock glass-card">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
                <div class="icon-premium glow-amber" style="background:var(--amber-light);"><i data-lucide="coins" style="color:var(--amber)"></i></div>
                <div><div style="font-size:14px;font-weight:800;color:#F59E0B">+15 pts earned!</div><div style="font-size:12px;color:#64748B">Best Answer selected</div></div>
            </div>
            <div style="background:#E2E8F0;border-radius:99px;height:8px;overflow:hidden;margin-bottom:7px"><div style="width:84%;height:100%;background:linear-gradient(90deg,#3D52A0,#7091E6);border-radius:99px"></div></div>
            <div style="font-size:12px;color:#64748B">840 / 1000 pts — 160 to Verified Tutor 🏅</div>
        </div>
        <div class="mock glass-card" style="background:linear-gradient(135deg,rgba(254,249,195,0.5),rgba(255,251,235,0.5))">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:13px">
                <div class="icon-premium" style="background:#fff;"><i data-lucide="coffee" style="color:var(--amber)"></i></div>
                <div><div style="font-weight:800;font-size:14px">Cafeteria Discount</div><div style="font-size:12px;color:#64748B">10% off your next meal</div></div>
                <span style="background:#F43F5E;color:#fff;border-radius:99px;padding:3px 10px;font-size:11px;font-weight:800;margin-left:auto">10% OFF</span>
            </div>
            <div style="background:#F59E0B;color:#fff;padding:9px;border-radius:10px;text-align:center;font-weight:800;font-size:13px">Redeem — 200 pts 🪙</div>
        </div>
        <div class="mock">
            <div style="font-size:13px;font-weight:800;margin-bottom:11px;color:#64748B">🏆 Leaderboard — This Month</div>
            <div style="display:flex;flex-direction:column;gap:9px">
                <div style="display:flex;align-items:center;gap:9px"><i data-lucide="award" style="color:var(--amber);width:20px;"></i><div class="av-premium av-xs" style="width:28px;height:28px;padding:2px;"><img src="https://i.pravatar.cc/28?img=65" alt="Sami"></div><span style="font-size:13px;font-weight:700;flex:1">Sami T. ✓</span><span style="font-weight:900;font-size:13px;color:#F59E0B">1,240</span></div>
                <div style="display:flex;align-items:center;gap:9px"><i data-lucide="medal" style="color:#94A3B8;width:20px;"></i><div class="av-premium av-xs" style="width:28px;height:28px;padding:2px;background:#CBD5E1"><img src="https://i.pravatar.cc/28?img=20" alt="Mona"></div><span style="font-size:13px;font-weight:700;flex:1">Mona A.</span><span style="font-weight:900;font-size:13px;color:#F59E0B">1,080</span></div>
                <div style="display:flex;align-items:center;gap:9px"><i data-lucide="medal" style="color:#B45309;width:20px;"></i><div class="av-premium av-xs" style="width:28px;height:28px;padding:2px;background:#FDE68A"><img src="https://i.pravatar.cc/28?img=47" alt="Rania"></div><span style="font-size:13px;font-weight:700;flex:1">Rania K.</span><span style="font-weight:900;font-size:13px;color:#F59E0B">960</span></div>
            </div>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="section" id="how">
    <div style="max-width:1100px;margin:0 auto">
        <div class="center">
            <div class="section-tag">⚡ Simple Process</div>
            <h2 class="section-title">How UniConnect works</h2>
            <p class="section-sub">Six steps — from creating your account to redeeming real discounts at campus venues.</p>
        </div>
        <div class="steps-grid">
            <div class="step"><div class="icon-premium glow-indigo" style="margin-bottom:16px"><i data-lucide="mail" style="color:var(--indigo)"></i></div><div class="step-num">01</div><div class="step-title">Register with university email</div><div class="step-desc">Sign up using your official Philadelphia University email. Only enrolled students can join — verified against the university registry. You receive <strong>+50 welcome points</strong> instantly.</div></div>
            <div class="step"><div class="icon-premium glow-indigo" style="margin-bottom:16px"><i data-lucide="help-circle" style="color:var(--indigo)"></i></div><div class="step-num">02</div><div class="step-title">Ask questions or help others</div><div class="step-desc">Post academic questions (costs 10 pts) and answer others to earn points back. Better answers get more upvotes. Best Answer earns +15 pts bonus automatically.</div></div>
            <div class="step"><div class="icon-premium glow-amber" style="margin-bottom:16px"><i data-lucide="coins" style="color:var(--amber)"></i></div><div class="step-num">03</div><div class="step-title">Earn points for every contribution</div><div class="step-desc">Every helpful action earns points — posting answers, receiving upvotes, and getting your answer accepted as the best. The more you help, the more you earn.</div></div>
            <div class="step"><div class="icon-premium glow-indigo" style="margin-bottom:16px"><i data-lucide="message-circle" style="color:var(--indigo)"></i></div><div class="step-num">04</div><div class="step-title">Request private tutoring sessions</div><div class="step-desc">Need deeper help? Request a one-on-one private chat session with a peer tutor. Real-time messaging powered by SignalR keeps conversations instant.</div></div>
            <div class="step"><div class="icon-premium glow-amber" style="margin-bottom:16px"><i data-lucide="trophy" style="color:var(--amber)"></i></div><div class="step-num">05</div><div class="step-title">Climb the faculty leaderboard</div><div class="step-desc">Rankings by faculty and time period. See who the top contributors are this week or all time. Compete with classmates in a friendly academic environment.</div></div>
            <div class="step" style="background:linear-gradient(135deg,#EEF2FF,#E8EEFF);border-color:#C7D7FF"><div class="icon-premium glow-indigo" style="margin-bottom:16px; background:#fff;"><i data-lucide="gift" style="color:var(--indigo)"></i></div><div class="step-num">06</div><div class="step-title">Redeem at campus venues</div><div class="step-desc">Exchange points for <strong>real discounts</strong> at the university cafeteria, library, bookshop, print centre and more. A unique coupon code is generated instantly — show it at the venue.</div></div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="section features-bg" id="features">
    <div style="max-width:1100px;margin:0 auto">
        <div class="center">
            <div class="section-tag">✨ Platform Features</div>
            <h2 class="section-title">Built for university life</h2>
            <p class="section-sub">Every feature designed around how students actually study, ask for help, and collaborate.</p>
        </div>
        <div class="features-grid">
            <div class="feat"><div class="icon-premium glow-indigo" style="background:#EEF2FF; margin-bottom:16px;"><i data-lucide="search" style="color:var(--indigo)"></i></div><div class="feat-title">Smart Question Feed</div><div class="feat-desc">Browse questions by faculty, course, or topic. Live search finds existing answers before you post — saving your 10 pts asking cost.</div></div>
            <div class="feat"><div class="icon-premium glow-emerald" style="background:#D1FAE5; margin-bottom:16px;"><i data-lucide="check-circle" style="color:var(--emerald)"></i></div><div class="feat-title">Best Answer System</div><div class="feat-desc">Question owners mark the most helpful answer. Best answers are pinned at the top and earn the contributor an automatic +15 pt reward.</div></div>
            <div class="feat"><div class="icon-premium glow-violet" style="background:#EDE9FE; margin-bottom:16px;"><i data-lucide="message-circle" style="color:var(--violet)"></i></div><div class="feat-title">Private Tutoring Chat</div><div class="feat-desc">One-on-one real-time chat with peer tutors powered by SignalR. Sessions are private and visible only to the two participants.</div></div>
            <div class="feat"><div class="icon-premium glow-amber" style="background:#FEF3C7; margin-bottom:16px;"><i data-lucide="coins" style="color:var(--amber)"></i></div><div class="feat-title">Points & Campus Rewards</div><div class="feat-desc">Earn points helping others and spend them at real campus locations — cafeteria, library, bookshop, print centre, gym and more.</div></div>
            <div class="feat"><div class="icon-premium glow-rose" style="background:#FFE4E6; margin-bottom:16px;"><i data-lucide="trophy" style="color:var(--rose)"></i></div><div class="feat-title">Faculty Leaderboard</div><div class="feat-desc">Real-time rankings filterable by faculty and time period. See how you stack up against peers in your faculty this week, month, or all time.</div></div>
            <div class="feat"><div class="icon-premium glow-indigo" style="background:#E0F2FE; margin-bottom:16px;"><i data-lucide="shield-check" style="color:var(--indigo)"></i></div><div class="feat-title">Admin Moderation</div><div class="feat-desc">Report inappropriate posts anytime — admin team reviews every report and can endorse or remove content to keep the platform safe and accurate.</div></div>
        </div>
    </div>
</section>

<!-- POINTS SYSTEM -->
<section class="pts-bg" id="rewards">
    <div class="pts-2col">
        <div>
            <div style="display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);border-radius:99px;padding:7px 18px;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;margin-bottom:16px">🪙 The Points System</div>
            <h2 style="font-size:clamp(28px,4vw,44px);font-weight:900;letter-spacing:-1px;line-height:1.15;color:#fff;margin-bottom:14px">Earn real rewards for helping others</h2>
            <p style="font-size:16px;color:rgba(255,255,255,.75);line-height:1.75;margin-bottom:24px">Every contribution earns points. Spend them on real discounts across the university campus — because helping classmates should have real benefits.</p>
            <div style="display:flex;flex-direction:column;gap:10px">
                <div style="display:flex;align-items:center;gap:11px;background:rgba(255,255,255,.1);border-radius:12px;padding:12px 16px"><span style="font-size:19px">🔒</span><span style="font-size:14px;color:rgba(255,255,255,.85);font-weight:600">University emails only — 100% verified students</span></div>
                <div style="display:flex;align-items:center;gap:11px;background:rgba(255,255,255,.1);border-radius:12px;padding:12px 16px"><span style="font-size:19px">🎟️</span><span style="font-size:14px;color:rgba(255,255,255,.85);font-weight:600">Instant coupon codes — show at the venue to redeem</span></div>
                <div style="display:flex;align-items:center;gap:11px;background:rgba(255,255,255,.1);border-radius:12px;padding:12px 16px"><span style="font-size:19px">🆓</span><span style="font-size:14px;color:rgba(255,255,255,.85);font-weight:600">Completely free — no credit card ever needed</span></div>
            </div>
        </div>
        <div>
            <div style="font-size:11px;font-weight:800;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.09em;margin-bottom:14px">HOW POINTS WORK:</div>
            <div class="pts-grid">
                <div class="pts-item"><div class="pts-ico"><i data-lucide="message-square" style="width:18px;"></i></div><div><div style="font-weight:700;font-size:13px">Post an Answer</div><div style="font-size:11px;opacity:.7">Help a classmate</div></div><div class="pts-val earn">+5</div></div>
                <div class="pts-item"><div class="pts-ico"><i data-lucide="thumbs-up" style="width:18px;"></i></div><div><div style="font-weight:700;font-size:13px">Get Upvoted</div><div style="font-size:11px;opacity:.7">Per upvote received</div></div><div class="pts-val earn">+10</div></div>
                <div class="pts-item"><div class="pts-ico"><i data-lucide="check-circle" style="width:18px;"></i></div><div><div style="font-weight:700;font-size:13px">Best Answer</div><div style="font-size:11px;opacity:.7">Marked as best</div></div><div class="pts-val earn">+15</div></div>
                <div class="pts-item"><div class="pts-ico"><i data-lucide="thumbs-up" style="width:18px;"></i></div><div><div style="font-weight:700;font-size:13px">Post Upvote</div><div style="font-size:11px;opacity:.7">Per upvote on your post</div></div><div class="pts-val earn">+5</div></div>
                <div class="pts-item"><div class="pts-ico"><i data-lucide="gift" style="width:18px;"></i></div><div><div style="font-weight:700;font-size:13px">Welcome Bonus</div><div style="font-size:11px;opacity:.7">On registration</div></div><div class="pts-val earn">+50</div></div>
                <div class="pts-item"><div class="pts-ico"><i data-lucide="help-circle" style="width:18px;"></i></div><div><div style="font-weight:700;font-size:13px">Post Question</div><div style="font-size:11px;opacity:.7">Costs points</div></div><div class="pts-val cost">−10</div></div>
            </div>
        </div>
    </div>
</section>

<!-- CAMPUS VENUES -->
